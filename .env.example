# ── K Clinics — environment ──────────────────────────────────────────────────
# Copy to .env (local) or set in Vercel project settings (production).

# Turn the CRM + client portal on (database + email + admin). Both true in prod;
# leave unset for the static GitHub Pages demo.
NEXT_PUBLIC_CRM_ENABLED=true
CRM_ENABLED=true

# Postgres (Neon or Supabase connection string).
# On Vercel's Postgres integration the runtime PREFERS these pooled/direct vars
# (set automatically by the integration; they take precedence over DATABASE_URL):
#   POSTGRES_PRISMA_URL      — pooled (runtime, serverless-safe)
#   POSTGRES_URL_NON_POOLING — direct (used by prebuild `prisma db push`)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Client portal auth + clinical encryption (required in prod) ──────────────
# Generate each with:  openssl rand -base64 32   (use DIFFERENT values)
CLIENT_JWT_SECRET="generate-a-different-long-random-string"
# K Academy (training) portal — optional; falls back to CLIENT/ADMIN secret.
ACADEMY_JWT_SECRET=""
# Must decode to exactly 32 bytes. NEVER change once health data exists.
HEALTH_ENCRYPTION_KEY="generate-a-32-byte-base64-key"
HEALTH_HMAC_KEY="optional-but-recommended-32-byte-base64-key"
# ── Encryption-key rotation (advanced, optional) ─────────────────────────────
# To rotate keys: set the NEW key in HEALTH_ENCRYPTION_KEY/HMAC above, move the
# OLD value(s) here (comma-separated) so existing records still decrypt, then
# set HEALTH_KEY_REENCRYPT=true to re-encrypt on the nightly cron.
HEALTH_ENCRYPTION_KEYS_OLD=""
HEALTH_HMAC_KEYS_OLD=""
HEALTH_KEY_REENCRYPT="false"

# ── Bot protection — Cloudflare Turnstile (STRONGLY recommended) ─────────────
# If unset, CAPTCHA is silently DISABLED (fails open) — set both in production.
TURNSTILE_SECRET_KEY=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Email — Resend (https://resend.com). Verify your sending domain.
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="K Clinics <hello@kclinics.co.uk>"
EMAIL_REPLY_TO="hello@kclinics.co.uk"
CLINIC_NOTIFY_EMAIL="frontdesk@kclinics.co.uk"
# Resend delivery webhook (open/click rates + auto-suppress bounces/complaints).
# Resend → Webhooks → Add Endpoint → https://kclinics.co.uk/api/webhooks/resend
# (events: email.delivered/opened/clicked/bounced/complained) → copy the signing
# secret here. In production the webhook fails closed until this is set.
RESEND_WEBHOOK_SECRET=""
# Live-chat email replies (Resend Inbound). When a visitor leaves their email and
# steps away, staff/AI replies are emailed with a Reply-To of
# chat-<token>@CHAT_INBOUND_DOMAIN; their reply is delivered by Resend Inbound to
# /api/webhooks/chat-inbound and threaded back into the same chat.
# Custom domain: set to mail.kclinics.co.uk and add the CNAME + CAA records Resend
# provides in Cloudflare. Sandbox/testing: set to the Resend inbound domain (the
# ….resend.app address — any localpart is accepted). Defaults to mail.<site host>.
CHAT_INBOUND_DOMAIN=""
RESEND_INBOUND_SECRET=""

# Admin auth + cron
ADMIN_JWT_SECRET="generate-a-long-random-string"
CRON_SECRET="generate-another-random-string"

# Public site URL (used in email + booking links)
NEXT_PUBLIC_SITE_URL="https://kclinics.co.uk"

# ── Stripe (booking & payments) ─────────────────────────────────────────────
# Card is saved at booking (no charge); charged on delivery / late-cancel.
STRIPE_SECRET_KEY="sk_live_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"          # from the Stripe webhook endpoint
SLOT_INTERVAL_MIN="15"                       # booking grid granularity (optional)
BOOKING_TIMEZONE="Europe/London"

# Headless WordPress (content + editable palette). Optional.

# ── Google Calendar (clinician availability sync) — optional ─────────────────
# Read-only (calendar.readonly): each clinician connects their own Google
# Calendar so personal busy-time blocks their booking slots; appears on the
# admin Calendar (one column per clinician). Google Cloud Console → APIs &
# Services → Credentials; enable the Google Calendar API. The redirect URI must
# EXACTLY match the route below or Google returns redirect_uri_mismatch.
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="xxx"
GOOGLE_REDIRECT_URI="https://kclinics.co.uk/api/admin/gcal/callback"
# Flip to true once Workspace is live to switch the sync on (parked otherwise).
GOOGLE_INTEGRATION_ENABLED="false"

# ── Google reviews & Business Profile — optional ─────────────────────────────
# GOOGLE_PLACE_ID: the clinic's Place ID. Powers the public "Share it on Google"
# write-review deep link AND identifies the business for the Places lookup below.
GOOGLE_PLACE_ID="ChIJxxxxxxxxxxxx"
# GOOGLE_PLACES_API_KEY: REQUIRED to show your real Google star-rating + reviews
# on the site (homepage, /reviews, blended aggregate). Without it, only in-house
# reviews show. Google Cloud Console → enable "Places API" → create an API key
# (restrict it to the Places API). This is the one to set if you want Google
# reviews live on the website.
GOOGLE_PLACES_API_KEY=""
# Business Profile MANAGEMENT API — import ALL Google reviews into the admin
# (Reviews page) and REPLY to them in-app. Needs: (1) these account/location
# numeric ids; (2) the shared GOOGLE_CLIENT_ID/SECRET, with this extra redirect
# URI registered in the OAuth client:
#   https://kclinics.co.uk/api/admin/integrations/google-business/callback
# (3) Google to grant your project access to the Business Profile APIs (a short
# request form — can take a few days); (4) the owner to click "Connect Google
# Business" on the admin Reviews page once. Reviews then sync nightly.
GOOGLE_BUSINESS_ACCOUNT_ID=""
GOOGLE_BUSINESS_LOCATION_ID=""

# ── SMS — Twilio — optional (email is the default channel) ───────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxx"
TWILIO_AUTH_TOKEN="xxxxxxxx"
TWILIO_FROM="+44xxxxxxxxxx"

# ── Accounting — Xero — optional ─────────────────────────────────────────────
XERO_CLIENT_ID="xxx"
XERO_CLIENT_SECRET="xxx"
# XERO_REDIRECT_URI defaults to ${NEXT_PUBLIC_SITE_URL}/api/admin/integrations/xero/callback
XERO_REDIRECT_URI=""

# ── Open banking — TrueLayer (live cashflow) — optional ──────────────────────
TRUELAYER_CLIENT_ID="xxx"
TRUELAYER_CLIENT_SECRET="xxx"
# TRUELAYER_REDIRECT_URI defaults to ${NEXT_PUBLIC_SITE_URL}/api/admin/integrations/truelayer/callback
TRUELAYER_REDIRECT_URI=""

# ── Translation helper — optional (EN/UK UI ships statically without this) ───
# Either provider activates it; set DEEPL_API_FREE=true for the free DeepL host.
DEEPL_API_KEY=""
DEEPL_API_FREE="false"
GOOGLE_TRANSLATE_KEY=""

# ── SEO — search-engine verification & instant indexing — all optional ──────
# Claim the property in each tool, then paste the token here (meta-tag method).
# Google Search Console → Settings → Ownership → HTML tag (the content="" value).
GOOGLE_SITE_VERIFICATION=""
# Bing Webmaster Tools → Settings → Verify (the msvalidate.01 content value).
BING_SITE_VERIFICATION=""
# Yandex Webmaster (only if targeting Yandex).
YANDEX_VERIFICATION=""
# IndexNow — instant recrawl for Bing/Yandex. Generate any 8–128 char hex key
# (e.g. `openssl rand -hex 16`); it's served at /indexnow-key.txt automatically.
INDEXNOW_KEY=""

# ── Telephony — yay.com VoIP ────────────────────────────────────────────────
# CALL LOGGING (inbound webhook — no API creds/IP allow-list needed):
# In yay → Web Hooks, set the "Call Ended" and "Voicemail Notify" hooks to:
#   https://kclinics.co.uk/api/integrations/yay?token=$YAY_WEBHOOK_SECRET
# and paste the same value in each hook's "Auth Token" field. Calls are logged
# immutably and matched to clients/suppliers by number; voicemail transcripts
# are stored automatically.
YAY_WEBHOOK_SECRET=""
# CLICK-TO-DIAL (optional, later — needs yay JSON-API creds from Settings → API,
# AND this server's egress IP added to yay's "Allowed IP ranges"):
YAY_AUTH_RESELLER=""
YAY_AUTH_USER="admin"
YAY_AUTH_PASSWORD=""
# Override the yay API base if needed (defaults to https://api.yay.com).
YAY_API_BASE=""

# ── Calendar — Hostinger (CalDAV) ───────────────────────────────────────────
# The clinic's email/calendar is on Hostinger (Google Workspace is parked; set
# GOOGLE_INTEGRATION_ENABLED=true to revive it later). Confirmed appointments are
# pushed to a shared clinic calendar via CalDAV. Provide the full calendar
# COLLECTION url (ending in /) plus the mailbox user + an app password.
HOSTINGER_CALDAV_URL=""
HOSTINGER_CALDAV_USER=""
HOSTINGER_CALDAV_PASS=""

# Email sending stays on Resend (above) regardless of mailbox host — no change
# needed for Hostinger email; replies simply land in the Hostinger mailbox.

# ── AI features — Anthropic — recommended ────────────────────────────────────
# Powers the live-chat AI assistant, the AI skin consultation, and AI marketing
# copy. Without it those features degrade to a safe "speak to the team" fallback.
# Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=""
AI_MONTHLY_CAP=""             # optional spend guard (number of AI calls/month)
AI_DISABLE_ESCALATION=""      # optional: "true" to stop AI handing off to staff

# ── Media uploads — Vercel Blob — required for image uploads ─────────────────
# Auto-set when you connect a Blob store in Vercel → Storage → Blob. Without it,
# admin image/media uploads return 503 (the rest of the app is unaffected).
BLOB_READ_WRITE_TOKEN=""

# ── Rate limiting — Upstash Redis — recommended ─────────────────────────────
# Backs login throttling, booking/AI rate limits etc. If absent, the app falls
# back to a Postgres-backed counter (still protected, just less ideal on
# serverless). Connect via Vercel → Storage → Upstash, or upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Ad-spend sync — Google Ads — optional ───────────────────────────────────
# Pulls campaign spend into the marketing performance dashboard.
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CUSTOMER_ID=""
GOOGLE_ADS_LOGIN_CUSTOMER_ID=""

# ── Notification inboxes — optional (fall back to CLINIC_NOTIFY_EMAIL) ───────
ACADEMY_NOTIFY_EMAIL=""       # new K-Academy training applications
CAREERS_NOTIFY_EMAIL=""       # new careers applications

# ── WhatsApp click-to-chat — optional ───────────────────────────────────────
# International number, digits only (e.g. 447700900000) for the WhatsApp link.
NEXT_PUBLIC_WHATSAPP=""

# See docs/INTEGRATIONS.md for what each integration powers and what degrades
# when a credential is absent.

# ── Seed an initial admin user (used by `npm run db:push && node prisma/seed.mjs`)
SEED_ADMIN_EMAIL="you@kclinics.co.uk"
SEED_ADMIN_PASSWORD="change-me-now"
SEED_ADMIN_NAME="Clinic Owner"

# Build & Issues board → GitHub bridge (optional). When set, logged items can be
# pushed to GitHub issues (and P0/P1 auto-create one) so work is actionable via
# the Claude↔GitHub flow. GITHUB_REPO is "owner/name"; the token needs issues:write.
GITHUB_TOKEN=""
GITHUB_REPO=""
