{
  "name": "k-clinics",
  "version": "1.0.0",
  "private": true,
  "description": "K Clinics — premium aesthetics & aesthetic dentistry, Islington London.",
  "scripts": {
    "dev": "node scripts/gen-image-manifest.mjs && next dev",
    "postinstall": "prisma generate",
    "prebuild": "node scripts/gen-image-manifest.mjs && node scripts/db-sync.mjs && node scripts/seed-rooms.mjs && node scripts/seed-services.mjs && node scripts/seed-catalogue.mjs && node scripts/seed-academy.mjs && node scripts/seed-lms.mjs",
    "db:seed:lms": "node scripts/seed-lms.mjs",
    "db:seed:rooms": "node scripts/seed-rooms.mjs",
    "db:seed:services": "node scripts/seed-services.mjs",
    "db:seed:catalogue": "node scripts/seed-catalogue.mjs",
    "db:seed:academy": "node scripts/seed-academy.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "motion": "^12.40.0",
    "geist": "^1.7.2",
    "@fontsource-variable/fraunces": "^5.1.1",
    "@prisma/client": "^7.8.0",
    "resend": "^6.12.4",
    "zod": "^4.4.3",
    "jose": "^6.2.3",
    "bcryptjs": "^3.0.3",
    "stripe": "^22.2.0",
    "@stripe/stripe-js": "^9.7.0",
    "@stripe/react-stripe-js": "^6.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.0.3",
    "@types/bcryptjs": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.5.1",
    "prisma": "^6.3.1"
  }
