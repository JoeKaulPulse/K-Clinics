{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "regions": ["lhr1"],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/dispatch",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "app/api/cron/daily/route.ts": { "maxDuration": 300 },
    "app/api/cron/dispatch/route.ts": { "maxDuration": 60 },
    "app/api/admin/export/route.ts": { "maxDuration": 300 }
  }
}
