// K Clinics CRM — data model
// Postgres in production (Neon/Supabase). `prisma db push` to sync.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ConsultStatus {
  NEW
  CONTACTED
  BOOKED
  COMPLETED
  CLOSED
}

enum InteractionType {
  NOTE
  CLINICAL
  COMPLAINT
  FOLLOW_UP
  CALL
  EMAIL
  SMS
  APPOINTMENT
  SYSTEM
}

enum EmailKind {
  CONSULT_REPLY
  CONSULT_NOTIFY
  BIRTHDAY
  FOLLOW_UP
  WIN_BACK
  REVIEW_REQUEST
  APPOINTMENT_REMINDER
  FORM_REMINDER
  PASSWORD_RESET
  CAMPAIGN
  MANUAL
  MEMBERSHIP
  CHAT
  ABANDONED_BOOKING
  NO_SHOW
  STAFF_DIGEST
  STAFF_NUDGE
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Role {
  OWNER // full access incl. settings & staff management
  ADMIN // full CRM access
  PRACTITIONER // clinician / doctor — full client + clinical (health) access
  FRONT_DESK // scheduling & client contact; no clinical health data
  DEVELOPER // build/CI/platform only — no client or clinical data (PRJ-63)
  CONTRACTOR // contracted tasks, time tracking, facility docs — no client data (PRJ-63)
  STAFF // legacy / general staff
}

enum AssessmentType {
  MEDICAL_HISTORY
  TREATMENT_CONSENT
  PRE_TREATMENT
  SKIN_PROFILE
  DENTAL_HISTORY
}

enum DiscountStatus {
  ACTIVE // claimed, not yet redeemed
  REDEEMED // applied to a booking/treatment
  REVOKED // staff revoked (e.g. abuse)
  BLOCKED // signup matched an existing claim — no discount granted
}

// Client loyalty: append-only points ledger. A client's balance is the sum of
// their non-expired rows. Earned 1 pt per £1 spent (100 pts = £1 off), plus
// bonuses (reviews, birthday) and referral credit. Spending writes a negative
// REDEMPTION row. Tune values in lib/client-loyalty.ts.
enum ClientPointsCategory {
  SPEND // earned from a completed/charged booking (1 pt per £1)
  REVIEW // left a review
  BIRTHDAY // annual birthday bonus
  REFERRAL // referral credit (referrer or referred friend)
  REDEMPTION // spent against a booking (negative) / refunded (positive)
  MANUAL // staff adjustment
  EXPIRY // points expired after 12 months (negative)
}

enum ReferralStatus {
  PENDING // code generated, no friend linked yet
  JOINED // a new client signed up via the code
  QUALIFIED // friend's first treatment ≥ £100 completed → both rewarded
  EXPIRED // friend's first treatment was < £100 (didn't qualify)
}

// Inclusive gender identity. Used to tailor treatment recommendations (and never
// to exclude anyone — non-binary / other / undisclosed see the full menu).
// OTHER pairs with Client.genderSelfDescribe for a free-text identity.
enum Gender {
  FEMALE
  MALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum BookingStatus {
  REQUESTED // same-day request awaiting staff approval (no card, slot not held)
  PENDING // created, awaiting card setup confirmation
  CONFIRMED // card on file, slot held
  COMPLETED // service delivered (may or may not be charged)
  CANCELLED
  NO_SHOW
}

enum AuditAction {
  BOOKING_CREATED
  BOOKING_RESCHEDULED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_NO_SHOW
  PRACTITIONER_ASSIGNED
  APPOINTMENT_STARTED
  APPOINTMENT_COMPLETED
  SOP_ACKNOWLEDGED
  MEDICAL_FLAG_REVIEWED
  PAYMENT_CHARGED
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  XERO_INVOICE_PUSHED
  XERO_REFUND_PUSHED
  ASSESSMENT_SUBMITTED
  ASSESSMENT_VIEWED
  NOTE_ADDED
  TIMEOFF_ADDED
  TIMEOFF_REQUESTED
  TIMEOFF_APPROVED
  TIMEOFF_DECLINED
  TIMEOFF_CANCELLED
  CONSUMABLE_USED
  REVIEW_REQUESTED
  REVIEW_RECEIVED
  REVIEW_PUBLISHED
  POINTS_AWARDED
  REWARD_REDEEMED
  SERVICE_PRICES_BULK
  SETTINGS_UPDATED
  CONSENT_REQUESTED
  CONSENT_SIGNED
  CONSENT_DECLINED
  BEFORE_PHOTO_CAPTURED
  CLIENT_DELETED
  CLIENT_EDITED
  DATA_EXPORTED
  DATA_IMPORTED // a data-migration step wrote records (e.g. WordPress import, BLD-187)
  SESSION_EDITED // a captured in-session answer was changed after first save (BLD-138)
  EMAIL_SENT // a bulk/transactional email batch was dispatched (e.g. BLD-242 re-permission)
  TASK_ASSIGNED // an internal task was assigned to a colleague (PRJ-63.11)
  TASK_COMPLETED // an assigned task was marked done (PRJ-63.11)
  ROOM_TURNOVER // a room was handed over for cleaning after a session (PRJ-63.11)
}

enum ReviewStatus {
  PENDING // request sent, awaiting the client's response
  SUBMITTED // client left a review — awaiting staff moderation
  APPROVED // approved for display / eligible to push to Google
  PUBLISHED // surfaced publicly / synced to Google Business
  HIDDEN // moderated out (spam, abusive, off-topic)
}

enum ReviewChannel {
  EMAIL
  SMS
}

enum TimeOffKind {
  HOLIDAY
  SICK
  TRAINING
  PERSONAL // appointment / personal time
  BLOCKED // manual block
  GCAL_BUSY // synced from Google Calendar
}

enum TimeOffStatus {
  PENDING // awaiting manager approval
  APPROVED
  DECLINED
  CANCELLED // withdrawn by the requester
}

enum TaskStatus {
  OPEN
  DONE
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
}

enum StockMoveReason {
  RECEIVED // stock in
  USED // consumed in a treatment
  WASTED // expired / damaged / spilled
  RETURNED // returned to supplier
  ADJUSTMENT // manual correction / stock-take
}

enum CashflowType {
  INCOME
  EXPENSE
}

enum CashCadence {
  ONE_OFF
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

// Projected income/expense lines used by the cashflow forecast.
model CashflowEntry {
  id          String       @id @default(cuid())
  type        CashflowType
  category    String // Treatments, Retail, Rent, Salaries, Consumables, Marketing…
  label       String
  amountPence Int
  cadence     CashCadence  @default(MONTHLY)
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean      @default(true)
  createdBy   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([active])
}

// Ring-fenced cash pots (replenishment, refurbishment, incentives, salary
// uplifts, operating slush). Contributions are skimmed from cashflow before
// 'available' operating cash is computed, guaranteeing the business reserve.
model CashReserve {
  id                       String   @id @default(cuid())
  name                     String
  targetPence              Int      @default(0) // 0 = no cap
  balancePence             Int      @default(0) // current ring-fenced balance
  monthlyContributionPence Int      @default(0) // planned monthly top-up
  color                    String?
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model Client {
  id                      String    @id @default(cuid())
  firstName               String
  lastName                String?
  email                   String    @unique
  phone                   String?
  dob                     DateTime? // drives birthday automation
  ageDeclaredAt           DateTime? // confirmed 18+ at signup
  gender                  Gender? // tailors treatment recommendations (inclusive)
  genderSelfDescribe      String? // free-text identity when gender = OTHER
  source                  String? // website, treatwell, fresha, referral…
  tags                    String[]  @default([])
  notes                   String?
  allergies               String? // client-stated allergies / dietary notes (hospitality + safety)
  marketingOptIn          Boolean   @default(false)
  // Demonstrable marketing consent (UK GDPR Art. 7 / PECR reg. 22): what wording
  // version, when, and how/where consent was captured — not just the boolean above.
  marketingConsentAt      DateTime?
  marketingConsentSource  String?
  marketingConsentVersion String?
  repermissionSentAt      DateTime? // BLD-242: re-permission (double opt-in) email sent to a legacy opt-in
  smsReminders            Boolean   @default(false) // client opted in to SMS confirmations & reminders
  concerns                String[]  @default([]) // skin/treatment goals & concerns (onboarding)
  onboardedAt             DateTime? // completed the welcome onboarding
  unsubscribed            Boolean   @default(false)
  unsubToken              String    @unique @default(cuid())
  lastVisitAt             DateTime?
  stripeCustomerId        String?   @unique

  // ── Membership (K Circle) — cached from rolling 12-month spend ──
  membershipTier      String? // current tier key (e.g. silver/gold/platinum); null = base member
  membership12moPence Int       @default(0) // realised spend over the trailing 12 months
  membershipUpdatedAt DateTime?

  // ── Client portal account ────────────────────────────────────────────────
  passwordHash   String? // set when the client creates a portal account
  emailVerified  DateTime?
  portalActive   Boolean   @default(false)
  sessionEpoch   Int       @default(0) // BLD-161: bump to revoke all outstanding portal JWTs (e.g. on password reset)
  locale         String    @default("en") // preferred portal language (en | uk)
  lastLoginAt    DateTime?
  // Password reset (hashed token + expiry).
  resetTokenHash String?
  resetTokenExp  DateTime?

  // ── First-visit discount (one-time, guardrailed) ─────────────────────────
  firstDiscountClaimed Boolean @default(false)
  signupIp             String?

  // ── Loyalty / referrals ──────────────────────────────────────────────────
  referralCode String? @unique // this client's own shareable code
  referredById String? // the Referral they joined through (if any)

  // ── Clinical safety flag ─────────────────────────────────────────────────
  // A concise, non-clinical alert (e.g. "Diabetes — see medical history") that
  // staff must review at the start of each appointment. Detailed health data
  // stays in the encrypted HealthAssessment records.
  medicalFlag      String?
  medicalFlagSetBy String?
  medicalFlagAt    DateTime?

  // ── Public loyalty leaderboard (PRJ-1.11) ────────────────────────────────
  // Only clients who explicitly opt in appear on the public leaderboard.
  // leaderboardPhotoUrl is staff-set after the client's written permission.
  leaderboardOptIn       Boolean @default(false)
  leaderboardPhotoUrl    String?
  leaderboardDisplayName String? // preferred display name (first name by default)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  consultations  Consultation[]
  interactions   Interaction[]
  appointments   Appointment[]
  bookings       Booking[]
  followUps      FollowUp[]
  aiAnalyses     AiAnalysis[]
  emails         EmailEvent[]
  assessments    HealthAssessment[]
  discountClaims DiscountClaim[]
  tasks          Task[]
  reviews        Review[]
  npsResponses   NpsResponse[]
  points         ClientPoints[]
  waitlist       WaitlistEntry[]
  referralsMade  Referral[]         @relation("ReferralsMade")
  referredVia    Referral?          @relation("ReferralReceived")
  callRecords    CallRecord[]

  @@index([createdAt])
  @@index([dob])
}

// ── Telephony (yay.com VoIP) ────────────────────────────────────────────────
// Immutable record of a phone call. Created when a call completes (yay webhook)
// and only ever enriched afterwards with the recording + transcript — the core
// call facts are never altered, so the log is an append-only audit trail.
enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallMatchType {
  CLIENT
  SUPPLIER
  STAFF
  UNKNOWN
}

// A supplier / business contact. Holds full contact info and links to the Xero
// contact so bills/invoices for them can be surfaced. Also used for caller-ID
// recognition on inbound calls.
model Supplier {
  id            String       @id @default(cuid())
  name          String
  category      String? // e.g. Consumables, Equipment, Utilities, Marketing
  contactName   String?
  email         String?
  phone         String?
  website       String?
  addressLine   String?
  city          String?
  postcode      String?
  country       String?      @default("GB")
  accountNumber String? // our account reference with them
  notes         String?
  xeroContactId String?      @unique // link to the Xero contact for bills/invoices
  active        Boolean      @default(true)
  createdBy     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  calls         CallRecord[]

  @@index([active])
  @@index([phone])
}

model CallRecord {
  id                String        @id @default(cuid())
  yayId             String        @unique // yay.com call/CDR id → idempotent ingest
  direction         CallDirection
  fromNumber        String
  toNumber          String
  status            String? // answered | missed | busy | failed | voicemail
  startedAt         DateTime
  answeredAt        DateTime?
  endedAt           DateTime?
  durationSec       Int           @default(0)
  agentExtension    String? // yay extension that handled the call
  agentEmail        String?
  recordingUrl      String? // yay-hosted recording
  recordingMime     String?
  transcript        String?       @db.Text
  transcriptStatus  String        @default("pending") // pending | ready | unavailable
  matchType         CallMatchType @default(UNKNOWN)
  matchedClientId   String?
  matchedClient     Client?       @relation(fields: [matchedClientId], references: [id], onDelete: SetNull)
  matchedSupplierId String?
  matchedSupplier   Supplier?     @relation(fields: [matchedSupplierId], references: [id], onDelete: SetNull)
  matchedLabel      String? // display label when neither client nor supplier
  notes             String? // free-text staff note (the only mutable field)
  raw               Json? // original webhook payload, for audit
  createdAt         DateTime      @default(now())

  @@index([startedAt])
  @@index([direction])
  @@index([matchedClientId])
}

model Consultation {
  id               String             @id @default(cuid())
  client           Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId         String
  category         String // aesthetics | dentistry | both
  treatments       String[]           @default([])
  concerns         String?
  message          String?
  preferredTime    String?
  preferredContact String? // email | phone | whatsapp
  medicalNotes     String?
  status           ConsultStatus      @default(NEW)
  assignedTo       String?
  notes            ConsultationNote[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status])
  @@index([createdAt])
}

model ConsultationNote {
  id             String       @id @default(cuid())
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  consultationId String
  body           String       @db.Text
  author         String // staff email
  createdAt      DateTime     @default(now())

  @@index([consultationId, createdAt])
}

model Interaction {
  id        String          @id @default(cuid())
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  type      InteractionType @default(NOTE)
  summary   String
  detail    String?
  author    String?
  pinned    Boolean         @default(false)
  createdAt DateTime        @default(now())

  @@index([clientId, createdAt])
  @@index([clientId, pinned])
}

model Appointment {
  id           String            @id @default(cuid())
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId     String
  treatment    String
  scheduledAt  DateTime
  status       AppointmentStatus @default(SCHEDULED)
  followUpSent Boolean           @default(false)
  reviewSent   Boolean           @default(false)
  createdAt    DateTime          @default(now())

  @@index([scheduledAt])
}

model Booking {
  id       String @id @default(cuid())
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  treatmentSlug  String
  treatmentTitle String
  startAt        DateTime
  endAt          DateTime
  durationMin    Int
  // Turnaround/cleanup minutes blocked AFTER the appointment (not client-facing,
  // not charged). The effective busy window is [startAt, endAt + bufferMin].
  bufferMin      Int      @default(0)
  pricePence     Int // 0 = on-consultation (amount set at charge time)

  status BookingStatus @default(PENDING)
  notes  String?

  // Hospitality: what the client would like prepared for their visit, plus any
  // allergy/dietary note. Aftercare acknowledgement: when the client confirmed
  // they have read & agreed to follow the aftercare instructions.
  refreshments   String[]  @default([])
  allergyNote    String?
  aftercareAckAt DateTime?

  // Loyalty points applied to this booking (money off). pointsRedeemed is the
  // ledger amount spent; pointsRedeemedPence is the £ value deducted (capped at
  // 50% of pricePence). Refunded if the booking is cancelled.
  pointsRedeemed      Int @default(0)
  pointsRedeemedPence Int @default(0)

  // Assigned clinician. Always usable internally; only offered to clients when
  // the 'allow_clinician_choice' setting is enabled.
  practitioner   AdminUser? @relation("PractitionerBookings", fields: [practitionerId], references: [id], onDelete: SetNull)
  practitionerId String?

  // Which site this appointment takes place at (multi-location).
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId String?

  // Rooms/equipment held for this appointment (e.g. a treatment room + the laser
  // machine). Auto-assigned at booking from what's free and capable.
  resources Resource[]

  // Front-of-house check-in: when reception marked the client as arrived (PRJ-63).
  // Distinct from startedAt (clinician beginning the treatment); surfaced to the
  // clinician view as an "Arrived" cue. Additive nullable column.
  arrivedAt DateTime?

  // Time tracking — actuals vs the scheduled duration.
  startedAt     DateTime?
  finishedAt    DateTime?
  actualMinutes Int?

  // Clinician's treatment note for this session (clinical record). Encrypted at
  // rest via the same app-level crypto used for health assessments.
  clinicalNoteEnc String?
  clinicalNoteBy  String?
  clinicalNoteAt  DateTime?

  // Pre-appointment safety checks the clinician confirms before starting.
  sopAcknowledgedAt     DateTime?
  sopAcknowledgedBy     String?
  // Per-step SOP checklist completion + captured client responses (encrypted).
  // JSON: { items: [{ step, checked, response }], completedAt }.
  sopChecklistEnc       String?
  medicalFlagReviewedAt DateTime?
  medicalFlagReviewedBy String?

  // Stripe: card saved at booking (no charge), charged later.
  stripeCustomerId      String?
  stripeSetupIntentId   String?
  stripePaymentMethodId String?

  // Service / late-cancel charge.
  chargePaymentIntentId String?
  chargedPence          Int?
  chargedAt             DateTime?
  // Refund (full or partial) of a charge, within the allowed window.
  refundedPence         Int?
  refundedAt            DateTime?
  refundReason          String?
  // Xero sales push (lib/xero.ts): the ACCREC invoice raised for the charge
  // ('PENDING' while a push is in flight — doubles as the idempotency claim),
  // and the credit note raised for each refund.
  xeroInvoiceId         String?
  xeroCreditNoteIds     String[]  @default([])

  // Cancellation.
  cancelledAt  DateTime?
  cancelReason String?
  cancelledBy  String? // 'client' | staff email
  lateCancel   Boolean   @default(false)
  feeWaived    Boolean   @default(false)

  // Client self-service link token.
  manageToken String @unique @default(cuid())

  remindersSent   Boolean  @default(false)
  // BLD-126: additional reminder windows (72h/48h) — additive, default false.
  reminder72hSent Boolean  @default(false)
  reminder48hSent Boolean  @default(false)
  rescheduleCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Marketing attribution (first-touch, captured from UTM/campaign params).
  attribSource        String?
  attribMedium        String?
  attribCampaign      String?
  attribLanding       String?
  gclid               String? // Google click id — for offline conversion upload to Google Ads
  marketingCampaign   MarketingCampaign? @relation(fields: [marketingCampaignId], references: [id], onDelete: SetNull)
  marketingCampaignId String?

  auditEvents AuditEvent[]
  reviews     Review[]
  items       BookingItem[] // line items: primary treatment + any upsell add-ons
  followUp    FollowUp? // post-treatment follow-up questionnaire
  liveSession AppointmentSession? // BLD-138 interactive in-clinic session

  @@index([startAt])
  @@index([status])
  @@index([clientId])
  @@index([practitionerId])
  @@index([marketingCampaignId])
}

// ── Interactive appointment session (BLD-138) ───────────────────────────────
// One per booking: the clinician-driven, sequenced walkthrough of the visit
// (arrival → safety → consent → treatment → aftercare → wrap-up). Per-step
// timings power the operations analytics the owner asked for (which sections
// take longest / get skipped). Clinical content does NOT live here — the
// treatment note and SOP responses stay in their existing encrypted homes on
// Booking; `data` holds only non-clinical operational answers. Manual edits to
// captured answers are audit-logged (SESSION_EDITED).
model AppointmentSession {
  id          String    @id @default(cuid())
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   String    @unique
  status      String    @default("ACTIVE") // ACTIVE | COMPLETED
  currentStep String    @default("arrival")
  startedBy   String // staff email driving the session
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  // Per-step timing: { [stepKey]: { enteredAt: ISO|null, seconds: number, visits: number, skipped?: boolean } }
  steps       Json      @default("{}")
  // Non-clinical operational answers: { [fieldKey]: { value: string, by: string, at: ISO } }
  data        Json      @default("{}")
  // ── Realtime coordination (BLD-138 v2) ──
  // Touchpoint log (append-only): [{ at: ISO, step, staffEmail, staffName, staffTitle?, staffPhoto? }]
  // — powers handoffs between devices and "who you're with" on the client's
  // live phone page. The active staff member is DERIVED from the tail (one
  // record of truth; see lib/appointment-session-server.ts).
  touchpoints Json      @default("[]")
  updatedAt   DateTime  @updatedAt

  @@index([startedAt])
}

// ── Marketing campaigns (umbrella orchestrator) ──────────────────────────────
// A campaign (e.g. "Valentine's Day") ties together email, paid ads, SEO and
// landing pages, and is what bookings/revenue are attributed against. It does
// not replace the email composer or page builder — it coordinates them.
enum CampaignStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  ENDED
}

model MarketingCampaign {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique // also the ?c= attribution token
  status             CampaignStatus @default(DRAFT)
  goal               String? // bookings | leads | revenue | awareness
  audience           String? // target segment / notes
  description        String?
  heroImage          String?
  startAt            DateTime?
  endAt              DateTime?
  budgetPence        Int? // planned spend (for ROI)
  spendPence         Int            @default(0) // recorded/synced ad spend
  spendSyncedAt      DateTime? // last time ad spend was pulled from a platform
  targetRevenuePence Int?
  targetBookings     Int?
  utmCampaign        String? // utm_campaign value used across channels
  channels           String[]       @default([]) // email | google_ads | meta | tiktok | seo | landing
  brief              String? // creative brief (feeds the AI assistant)
  aiDraft            Json? // last AI-generated content pack (owner reviews before use)
  createdBy          String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  bookings Booking[]

  @@index([status])
}

// ── Service catalogue (CRM-managed pricing) ──────────────────────────────────
// Marketing copy lives in lib/treatments.ts; the bookable + priced catalogue
// lives here so prices, costs, durations and offers are editable in the CRM.

// Public presentation state for a service/variant. Prices are always kept
// internally; this only controls what the public site shows + whether it books.
//   NORMAL       – price shown, bookable online (offers applied)
//   CONSULTATION – price hidden ("On consultation"), still bookable as a £0 hold
//   COMING_SOON  – not bookable, shown with a "Coming soon" badge + enquiry CTA
//   UNAVAILABLE  – not bookable, shown with a "Currently unavailable" badge + enquiry
enum ServiceStatus {
  NORMAL
  CONSULTATION
  COMING_SOON
  UNAVAILABLE
}

model Service {
  id            String        @id @default(cuid())
  slug          String        @unique
  treatmentSlug String // links to a marketing Treatment (lib/treatments.ts)
  name          String
  category      String        @default("aesthetics") // aesthetics | dentistry
  vatClass      String? // STANDARD | REDUCED | ZERO | EXEMPT (null → derived: dentistry EXEMPT, else STANDARD)
  order         Int           @default(0)
  active        Boolean       @default(true)
  status        ServiceStatus @default(NORMAL) // service-level public state
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  variants ServiceVariant[]
  offers   ServiceOffer[]

  @@index([treatmentSlug])
  @@index([active])
}

model ServiceVariant {
  id          String         @id @default(cuid())
  service     Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId   String
  name        String // e.g. "Full Face", "Signature Express (30 min)"
  durationMin Int            @default(30)
  pricePence  Int // single-session retail price (0 = on consultation)
  costPence   Int? // cost of goods/service, for margin tracking
  // Course/package options as [{ sessions, totalPence }], cheaper per-session.
  courses     Json?
  order       Int            @default(0)
  active      Boolean        @default(true)
  status      ServiceStatus? // optional per-option override of the service status
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  offers       ServiceOffer[]
  bookingItems BookingItem[]

  @@index([serviceId, active])
}

enum OfferScope {
  ALL // every service
  SERVICE // one service (all its variants)
  VARIANT // a single variant
}

// Special offers / discounts. Promoted ones surface on the marketing site and
// in client portals. Applied automatically to matching booking line items.
model ServiceOffer {
  id             String          @id @default(cuid())
  name           String // shown to clients, e.g. "Summer Skin — 20% off"
  scope          OfferScope      @default(ALL)
  service        Service?        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId      String?
  variant        ServiceVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId      String?
  percentOff     Int? // 0–100
  amountOffPence Int? // fixed amount off (alternative to percent)
  startAt        DateTime?
  endAt          DateTime?
  promoted       Boolean         @default(true) // surface on site + portal
  active         Boolean         @default(true)
  createdBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([active, promoted])
  @@index([serviceId])
  @@index([variantId])
}

// A booking is one or more line items: the primary treatment plus any upsell
// add-ons taken in the same slot (often at a discount).
model BookingItem {
  id            String          @id @default(cuid())
  booking       Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId     String
  variant       ServiceVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId     String?
  treatmentSlug String
  label         String // e.g. "Laser Hair Removal — Full Face"
  sessions      Int             @default(1) // 1 = single; >1 = course booked
  durationMin   Int             @default(0)
  pricePence    Int             @default(0) // retail before discount
  discountPence Int             @default(0) // welcome/offer/upsell discount applied
  isAddon       Boolean         @default(false)
  createdAt     DateTime        @default(now())

  @@index([bookingId])
}

model EmailEvent {
  id           String      @id @default(cuid())
  client       Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId     String?
  kind         EmailKind
  to           String
  subject      String
  status       EmailStatus @default(QUEUED)
  providerId   String?
  campaignId   String?
  error        String?
  meta         Json?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  complainedAt DateTime?
  opens        Int         @default(0)
  clicks       Int         @default(0)
  createdAt    DateTime    @default(now())

  @@index([clientId])
  @@index([kind, createdAt])
  @@index([campaignId])
  @@index([providerId])
}

model Campaign {
  id            String    @id @default(cuid())
  name          String
  subject       String
  body          String
  segment       String? // tag or rule used to select recipients
  // Lifecycle: DRAFT (work in progress) → SCHEDULED (queued for scheduledAt) →
  // SENDING (cron picked it up) → SENT. Defaults to SENT so existing rows,
  // which were all sent immediately, keep their meaning.
  status        String    @default("SENT")
  scheduledAt   DateTime?
  // Sender + audience captured so a draft/scheduled send can be re-sent later.
  fromName      String?
  replyTo       String?
  preheader     String?
  audienceType  String? // all | segment | tag
  audienceValue String?
  createdBy     String?
  // A/B subject test: variant B subject, % of the audience used per variant in
  // the test, when to pick a winner, and the winner ('A'|'B') once decided.
  subjectB      String?
  abSamplePct   Int?
  abDecideAt    DateTime?
  abWinner      String?
  sentAt        DateTime?
  recipients    Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([status, scheduledAt])
}

// Per-link click counts for a campaign, accrued from Resend click webhooks, so
// the dashboard can show which links people actually clicked.
model EmailLinkClick {
  id         String   @id @default(cuid())
  campaignId String?
  url        String
  clicks     Int      @default(0)
  updatedAt  DateTime @default(now()) @updatedAt

  @@unique([campaignId, url])
  @@index([campaignId])
}

// A reusable marketing-email design (subject + sender + content blocks) a user
// can start a new campaign from. Distinct from the static transactional-email
// previews shown on /admin/marketing/templates.
model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String?
  preheader String?
  fromName  String?
  body      String // JSON EmailBlock[]
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  onboardedAt  DateTime? // completed the staff welcome onboarding
  passwordHash String
  role         Role      @default(STAFF)
  active       Boolean   @default(true)

  // Per-user permission overrides on top of the role defaults.
  // grant = always allow these keys; revoke = always deny these keys.
  permGrant  String[] @default([])
  permRevoke String[] @default([])

  // ── Scheduling & clinical capability ──────────────────────────────────────
  isClinician  Boolean  @default(false) // bookable as a practitioner
  title        String? // e.g. "Aesthetic Doctor"
  color        String? // calendar colour (hex)
  // Treatment slugs this person is competent to deliver (empty = all).
  competencies String[] @default([])

  // ── Public team-page profile (single source of truth → /team) ──
  publicProfile   Boolean @default(false) // show on the public team page
  photoUrl        String? // headshot URL
  publicPhone     String? // shown on the team card (optional)
  bio             String? // public bio
  yearsExperience Int?
  credentials     String? // e.g. "GMC reg. · Aesthetic Medicine"
  profileOrder    Int     @default(0) // ordering within their group

  // Google Calendar integration (busy-time sync + event push).
  googleCalendarId   String?
  googleRefreshToken String?

  locale                 String  @default("en") // CRM UI language (en | uk)
  preferredDashboardView String? // PRJ-63: OWNER/ADMIN can pin a role-view to land on (null = role default)

  // ── Two-factor authentication (TOTP) ────────────────────────────────────
  totpSecret     String? // encrypted base32 secret (lib/crypto keyring)
  totpEnabledAt  DateTime? // set once enrolment is confirmed with a valid code
  recoveryCodes  String[]             @default([]) // bcrypt-hashed single-use recovery codes
  sessionEpoch   Int                  @default(0) // bump to revoke all existing sessions
  financePinHash String? // bcrypt-hashed 6-digit PIN to unlock financial data
  passkeys       WebAuthnCredential[]

  lastLoginAt DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  schedules       StaffSchedule[]
  timeOff         StaffTimeOff[]
  bookings        Booking[]           @relation("PractitionerBookings")
  assignedTasks   Task[]              @relation("TaskAssignee")
  locations       Location[]          @relation("StaffLocations")
  reviews         Review[]            @relation("ClinicianReviews")
  points          StaffPoints[]
  redemptions     RewardRedemption[]
  notifications   StaffNotification[]
  timeEntries     TimeEntry[]
  contractorTasks ContractorTask[]    @relation("ContractorTaskAssignee")
}

// PRJ-63 — staff time tracking. A TimeEntry is an open/closed interval of either
// a SHIFT (clocked in) or a BREAK (incl. the dashboard lunch break). Net worked
// time = sum(SHIFT) − sum(BREAK). Drives clock in/out, the lunch-break action and
// the contractor timesheet. Additive: new enum + new table.
enum TimeEntryKind {
  SHIFT
  BREAK
}

model TimeEntry {
  id        String        @id @default(cuid())
  user      AdminUser     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  kind      TimeEntryKind @default(SHIFT)
  startedAt DateTime      @default(now())
  endedAt   DateTime? // null = still open (on shift / on break)
  note      String? // e.g. "Lunch" for a break
  createdAt DateTime      @default(now())

  @@index([userId, startedAt])
  @@index([userId, endedAt])
}

// PRJ-63 — facility knowledge base. Floor/electrical/plumbing plans, equipment
// locations, where-to-find-things and instructions. Powers the contractor view
// and is useful to all staff. fileUrl is a Vercel Blob URL (image or PDF).
// Additive: new enum + new table; locationId is a plain scope tag (no FK) so it
// doesn't require touching the Location model.
enum FacilityDocType {
  FLOOR_PLAN
  ELECTRICAL
  PLUMBING
  EQUIPMENT
  INSTRUCTION
  OTHER
}

model FacilityDoc {
  id          String          @id @default(cuid())
  title       String
  type        FacilityDocType @default(OTHER)
  fileUrl     String // Vercel Blob URL (image or PDF)
  isPdf       Boolean         @default(false)
  description String?
  locationId  String? // optional scope tag (Location.id)
  tags        String[]        @default([])
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?

  @@index([type, order])
  @@index([locationId])
}

// PRJ-63 — contracted work assigned to a contractor (maintenance, fit-out, jobs).
// No client/clinical/financial data. Additive: new enum + new table.
enum ContractorTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
}

model ContractorTask {
  id           String               @id @default(cuid())
  title        String
  description  String?
  status       ContractorTaskStatus @default(OPEN)
  assignee     AdminUser?           @relation("ContractorTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId   String?
  // PRJ-63: optionally assign to a self-onboarded Contractor (reception check-in)
  // instead of/as well as a staff AdminUser. Both are nullable; either may hold it.
  contractor   Contractor?          @relation("ContractorTaskContractor", fields: [contractorId], references: [id], onDelete: SetNull)
  contractorId String?
  dueAt        DateTime?
  locationId   String? // optional scope tag (Location.id)
  createdBy    String? // staff email who assigned it
  completedAt  DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([assigneeId, status])
  @@index([contractorId, status])
  @@index([status, dueAt])
}

// PRJ-63 — contractors sign in at reception like clients, NOT as admin staff.
// A Contractor is a lightweight self-onboarded profile deliberately isolated from
// AdminUser so the PUBLIC check-in endpoint never creates or touches a privileged
// account (no login, no session, no permissions). An admin approves new profiles.
// Additive: new enum + new tables + a nullable FK on ContractorTask only.
enum ContractorStatus {
  PENDING // self-registered at reception, awaiting admin approval
  APPROVED // verified by an admin
  BLOCKED // barred from site
}

model Contractor {
  id         String           @id @default(cuid())
  name       String
  email      String?
  phone      String?
  company    String?
  tradeType  String?
  status     ContractorStatus @default(PENDING)
  note       String?
  approvedAt DateTime?
  approvedBy String? // staff email who approved
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  visits ContractorVisit[]
  tasks  ContractorTask[]  @relation("ContractorTaskContractor")

  @@index([status])
  @@index([email])
}

// One on-site visit (checked in -> checked out). The on-site task view is served
// via the visit's high-entropy `secret` capability (httpOnly cookie) — there is no
// password or admin session. Looked up by `id` (findUnique on the PK), with the
// secret compared in timing-safe fashion (mirrors the kiosk session pattern).
model ContractorVisit {
  id           String     @id @default(cuid())
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  contractorId String
  secret       String // high-entropy capability secret; required to read the visit
  checkedInAt  DateTime   @default(now())
  checkedOutAt DateTime?
  locationId   String? // optional scope tag (Location.id)
  note         String?
  createdAt    DateTime   @default(now())

  @@index([contractorId, checkedInAt])
}

// WebAuthn passkeys (platform authenticators — Face ID / Touch ID / Windows
// Hello). Used as a strong step-up before the full data export.
model WebAuthnCredential {
  id           String    @id @default(cuid())
  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  adminUserId  String
  credentialId String    @unique // base64url
  publicKey    Bytes // COSE public key
  counter      Int       @default(0)
  transports   String[]  @default([])
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([adminUserId])
}

// ── Staff gamification: append-only points ledger ────────────────────────────
// Every award/deduction is a row, so a member's score is the sum of their
// entries — fully auditable. Driven by commercial signals (efficiency, waste)
// and, most importantly, client reviews.
enum PointsCategory {
  REVIEW // client review rating
  EFFICIENCY // on/under booked treatment time
  CONSUMABLES // minimal waste
  PUNCTUALITY // started on time
  PERFORMANCE // manager-awarded (reviews, KPIs)
  FRIENDLINESS // manager/feedback-awarded
  TEAMWORK
  MANUAL // ad-hoc manager adjustment
  REDEMPTION // points spent on a reward
  REVENUE // revenue delivered (charged treatments)
  UPSELL // add-ons / enhancements sold
  REBOOK // secured a repeat booking
}

model StaffPoints {
  id        String         @id @default(cuid())
  staff     AdminUser      @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId   String
  points    Int // may be negative (waste, redemption)
  category  PointsCategory
  reason    String
  bookingId String? // optional source booking
  reviewId  String? // optional source review
  awardedBy String? // staff email, or 'system'
  createdAt DateTime       @default(now())

  @@index([staffId, createdAt])
  @@index([category])
}

// ── Rewards catalogue: what staff can spend their points on ───────────────────
// Manager-curated perks. A redemption deducts points via a REDEMPTION ledger row
// (so balances stay a pure sum), and is tracked here through to fulfilment.
model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  costPoints  Int
  emoji       String? // small visual marker in the catalogue
  active      Boolean  @default(true)
  stock       Int? // null = unlimited
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redemptions RewardRedemption[]

  @@index([active, sortOrder])
}

enum RedemptionStatus {
  PENDING // requested, awaiting manager fulfilment
  FULFILLED // perk granted
  DECLINED // rejected (points refunded)
}

model RewardRedemption {
  id         String           @id @default(cuid())
  reward     Reward           @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  rewardId   String
  staff      AdminUser        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId    String
  costPoints Int // snapshot of cost at redemption time
  status     RedemptionStatus @default(PENDING)
  note       String?
  decidedBy  String? // manager email
  decidedAt  DateTime?
  createdAt  DateTime         @default(now())

  @@index([staffId, createdAt])
  @@index([status])
}

// ── Clinic locations (multi-site) ────────────────────────────────────────────
// The clinic starts single-site; this model lets new locations be added and
// clinicians assigned to one or more. A clinician's working location on a given
// day comes from their weekly schedule (one block per weekday → one location
// per day), so they're never in two places at once.
model Location {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  addressLine String?
  city        String?
  postcode    String?
  phone       String?
  email       String?
  color       String? // calendar colour
  active      Boolean  @default(true)
  isPrimary   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff     AdminUser[]     @relation("StaffLocations")
  schedules StaffSchedule[]
  bookings  Booking[]
  closures  ClinicClosure[]
  resources Resource[]
  dayCloses DayClose[]

  @@index([active])
}

// ── Weekly working pattern per staff member ──────────────────────────────────
model StaffSchedule {
  id            String    @id @default(cuid())
  staff         AdminUser @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId       String
  dayOfWeek     Int // 0=Sun … 6=Sat
  startMin      Int // minutes from midnight
  endMin        Int
  // Optional daily break (e.g. lunch), as minutes from midnight. When set, the
  // window [breakStartMin, breakEndMin] is unavailable within the working day.
  breakStartMin Int?
  breakEndMin   Int?
  location      Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId    String?
  createdAt     DateTime  @default(now())

  @@index([staffId, dayOfWeek])
}

// ── Clinic-wide closures & holidays ──────────────────────────────────────────
// Blocks bookings for ALL staff over a date/range. locationId null = every site.
model ClinicClosure {
  id         String    @id @default(cuid())
  startAt    DateTime
  endAt      DateTime
  allDay     Boolean   @default(true)
  reason     String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  locationId String? // null = applies to all locations
  createdBy  String?
  createdAt  DateTime  @default(now())

  @@index([startAt, endAt])
}

// ── Bookable rooms / equipment ───────────────────────────────────────────────
// Two kinds, both held by a booking:
//  • ROOM      — a named treatment room (capacity 1). `tags` list what it can host
//                ('aesthetics', 'dental', 'laser'…); a booking is auto-assigned a
//                free room whose tags match the treatment's needs.
//  • EQUIPMENT — shared machines (laser/HIFU), matched by `slug` to a treatment's
//                requiresResource; `capacity` caps concurrent use.
// If nothing matching exists, the requirement isn't enforced (clinics that haven't
// configured rooms/equipment aren't blocked).
model Resource {
  id         String       @id @default(cuid())
  slug       String // EQUIPMENT: e.g. 'laser'. ROOM: a short code e.g. 'g1'.
  name       String
  kind       ResourceKind @default(EQUIPMENT)
  tags       String[]     @default([]) // ROOM capabilities, e.g. ['aesthetics','laser']
  floor      String? // e.g. 'G' / 'LG' — for display/grouping
  capacity   Int          @default(1) // EQUIPMENT: concurrent uses. ROOM: 1.
  active     Boolean      @default(true)
  location   Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  bookings Booking[]

  // Daily prep/turnover state for this room (ROOM kind only). One row per day.
  roomPreps RoomPrep[]

  // Scheduled block-outs (e.g. a contractor on site) — BLD-198.
  roomClosures RoomClosure[]

  // Which equipment is physically placed in a ROOM. Self-relation: a room holds
  // many equipment; a piece of equipment can sit in many rooms. Owner-managed and
  // changeable over time. (Informational today; available to drive assignment.)
  equipment Resource[] @relation("RoomEquipment")
  inRooms   Resource[] @relation("RoomEquipment")

  @@index([slug, active])
  @@index([kind, active])
}

enum ResourceKind {
  ROOM
  EQUIPMENT
}

// ── Daily room prep / turnover state (PRJ-63) ───────────────────────────────
// One row per room per day. Powers the clinician + receptionist views and the
// dashboard arrival-prep checklist: a receptionist marking a room READY surfaces
// live to the clinician (polled). This is a NEW table, so the compound @@unique
// is created fresh with no existing rows to dedupe — it passes the `prisma db
// push` gate (which only refuses adding @unique to an *existing* table) and lets
// us upsert cleanly by (roomId, date).
model RoomPrep {
  id        String         @id @default(cuid())
  room      Resource       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId    String
  date      DateTime       @db.Date // DateOnly — the clinic day this state is for
  status    RoomPrepStatus @default(DIRTY)
  cleanedAt DateTime?
  cleanedBy String? // staff email who set it READY
  note      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([roomId, date])
  @@index([date, status])
}

enum RoomPrepStatus {
  DIRTY
  CLEANING
  READY
}

// ── Time off / busy blocks (manual or Google-Calendar-synced) ───────────────
model StaffTimeOff {
  id          String        @id @default(cuid())
  staff       AdminUser     @relation(fields: [staffId], references: [id], onDelete: Cascade)
  staffId     String
  kind        TimeOffKind   @default(BLOCKED)
  status      TimeOffStatus @default(APPROVED) // self-service requests start PENDING
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean       @default(false)
  reason      String?
  requestedBy String? // email of the person who created it
  reviewedBy  String? // email of the manager who approved/declined
  reviewedAt  DateTime?
  reviewNote  String?
  gcalEventId String?       @unique // dedupe Google-synced busy blocks
  createdAt   DateTime      @default(now())

  @@index([staffId, startAt])
  @@index([startAt, endAt])
  @@index([status])
}

// ── Internal tasks / to-dos ─────────────────────────────────────────────────
// Every task carries a stable human-readable reference (`ref`) for tracing,
// search and identification: top-level tasks are TSK-<seq> (seq is a Postgres
// sequence, so numbering is race-free; gaps are normal), and sub-tasks branch
// from their parent's ref (TSK-12 → TSK-12.1 → TSK-12.1.1). Refs never change
// once assigned. See lib/task-refs.ts.
//
// NB: seq/ref carry NO @unique — the deploy gate (`prisma db push` without
// --accept-data-loss) refuses to add unique constraints to existing tables.
// Uniqueness is guaranteed structurally instead: seq by the sequence, root refs
// by derivation from seq, child refs by lock-serialised allocation + a
// self-healing dedupe pass (lib/task-refs.ts).
model Task {
  id          String       @id @default(cuid())
  seq         Int          @default(autoincrement())
  ref         String?
  title       String
  detail      String?
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  dueAt       DateTime?
  assignee    AdminUser?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId  String?
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    String?
  // Sub-tasks: deleting a parent removes its sub-tasks with it (the branch is one unit of work).
  parent      Task?        @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  parentId    String?
  subtasks    Task[]       @relation("TaskSubtasks")
  createdBy   String?
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status])
  @@index([assigneeId, status])
  @@index([dueAt])
  @@index([parentId])
}

// ── Inventory: consumables & stock control ──────────────────────────────────
model StockItem {
  id          String   @id @default(cuid())
  name        String
  category    String? // e.g. "Injectables", "Consumables", "PPE"
  brand       String? // product brand (e.g. "iS Clinical")
  size        String? // pack size (e.g. "180ml", "15ml")
  unit        String   @default("unit") // vial, ml, syringe, unit, pack
  sku         String?
  supplier    String?
  moq         Int      @default(1) // minimum order quantity honoured at reorder
  currentQty  Float    @default(0)
  lowStockAt  Float    @default(0) // alert threshold
  costPence   Int? // unit cost for valuation (wholesale, ex VAT)
  retailPence Int? // retail price (RRP inc VAT) when sold to clients
  isRetail    Boolean  @default(false) // sold to clients (vs professional-use)
  active      Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movements StockMovement[]

  @@index([active])
}

model StockMovement {
  id        String          @id @default(cuid())
  item      StockItem       @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String
  delta     Float // + in, − out
  reason    StockMoveReason
  batchNo   String? // lot/batch number (compliance)
  expiry    DateTime? // batch expiry (on receipt)
  bookingId String? // optional link to the treatment that used it
  note      String?
  by        String? // staff email
  createdAt DateTime        @default(now())

  @@index([itemId, createdAt])
  @@index([expiry])
}

// ── OAuth connections to external services (Xero, TrueLayer bank feed) ───────
// Tokens are stored encrypted (AES-256-GCM) in `tokensEnc`, never in clear.
model ExternalConnection {
  id         String   @id @default(cuid())
  provider   String   @unique // 'xero' | 'truelayer'
  tokensEnc  String // encrypted JSON { access, refresh, expiresAt }
  accountRef String? // Xero tenantId / bank account id
  label      String? // org / account name for display
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Settings: key/value toggles & config, editable in admin ─────────────────
model Setting {
  key       String   @id
  value     String // JSON or scalar string
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Owner-managed integration credentials (API keys / secrets) entered in the
// admin instead of hosting env vars. Encrypted at rest (encryptJson); the
// resolver in lib/secrets.ts prefers these over process.env, so they take
// effect without a redeploy. `name` is the env-var name (e.g. RESEND_API_KEY);
// @id avoids @unique so the no-data-loss deploy gate accepts the new table.
model ManagedSecret {
  name      String   @id
  valueEnc  String   @db.Text
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ── SOP documents per treatment type ────────────────────────────────────────
model TreatmentSop {
  id            String   @id @default(cuid())
  treatmentSlug String   @unique
  title         String
  content       String // markdown-ish steps; rendered read-only
  version       Int      @default(1)
  updatedAt     DateTime @updatedAt
  updatedBy     String?
}

// ── Immutable audit log — every action across the booking→treatment→payment
// lifecycle. Append-only: never updated or deleted. ─────────────────────────
model AuditEvent {
  id        String      @id @default(cuid())
  action    AuditAction
  booking   Booking?    @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bookingId String?
  clientId  String?
  actor     String // staff email or 'client' / 'system'
  actorRole String?
  summary   String
  meta      Json?
  createdAt DateTime    @default(now())

  @@index([bookingId, createdAt])
  @@index([clientId, createdAt])
  @@index([createdAt])
}

// ── Immutable, encrypted clinical record ─────────────────────────────────────
// Health questionnaires / assessments are append-only: a submission is NEVER
// updated or deleted. Corrections create a new version that `supersedesId` the
// prior one. Answer payloads are encrypted at rest (AES-256-GCM) via the app
// key; `integrityHash` (HMAC-SHA256) lets us detect any tampering. Access is
// restricted to the owning client and clinical staff.
// BLD-190 — admin-managed EXTRA questions appended to a code-defined health form.
// The base (clinically-reviewed) questions stay versioned in code; these add-on
// questions are merged in at render + clinician display. Additive table only.
model FormQuestion {
  id               String   @id @default(cuid())
  questionnaireKey String // e.g. 'medical-history' (matches Questionnaire.key)
  prompt           String
  fieldType        String   @default("text") // single | multi | boolean | text | longtext | scale | date
  help             String?
  required         Boolean  @default(false)
  options          Json? // [{ value, label }] for single/multi
  order            Int      @default(0)
  active           Boolean  @default(true)
  createdBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([questionnaireKey, active, order])
}

model HealthAssessment {
  id       String @id @default(cuid())
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  type         AssessmentType
  version      Int            @default(1)
  supersedesId String?        @unique // points to the prior version, if a correction

  // Encrypted answer blob (base64: iv.tag.ciphertext) — never stored in plain.
  cipher           String
  // HMAC-SHA256 over the ciphertext + metadata, for tamper detection.
  integrityHash    String
  // Non-sensitive metadata kept in clear for listing/filtering.
  questionnaireKey String // which questionnaire definition + version
  summary          Json? // redacted, non-clinical summary (e.g. {complete:true})
  sourceLocale     String @default("en") // language the client filled this in

  submittedAt DateTime @default(now())
  submittedIp String?
  // Snapshot of who/what the assessment was for (e.g. an upcoming booking).
  bookingId   String?

  @@index([clientId, type])
  @@index([submittedAt])
}

// ── First-visit discount ledger (abuse guardrail) ───────────────────────────
// One ACTIVE claim per real person. We normalise email/phone and derive a
// name+DOB key; a new signup matching any prior ACTIVE/REDEEMED claim is
// BLOCKED (no discount) and flagged for staff, who can override.
model DiscountClaim {
  id       String @id @default(cuid())
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  code    String         @unique
  status  DiscountStatus @default(ACTIVE)
  percent Int            @default(15)

  // Normalised identity fingerprints used to detect repeat claims.
  emailNorm  String
  phoneNorm  String?
  nameDobKey String?
  ip         String?

  flagged           Boolean  @default(false) // matched a prior claim / looks suspicious
  reviewedBy        String? // staff email if overridden
  redeemedBookingId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([emailNorm])
  @@index([phoneNorm])
  @@index([nameDobKey])
  @@index([status])
}

// ── Client loyalty ledger ─────────────────────────────────────────────────
// Append-only. Balance = sum of points where not expired. Earned points carry
// an expiresAt (12 months out); redemptions/refunds/expiry rows don't expire.
model ClientPoints {
  id         String               @id @default(cuid())
  client     Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  points     Int // may be negative (redemption, expiry)
  category   ClientPointsCategory
  reason     String
  bookingId  String? // source booking (SPEND / REDEMPTION)
  reviewId   String? // source review (REVIEW — idempotency)
  referralId String? // source referral (REFERRAL)
  awardedBy  String               @default("system") // 'system' | staff email
  expiresAt  DateTime? // when this earned lot expires (null = never)
  createdAt  DateTime             @default(now())

  @@index([clientId])
  @@index([clientId, category])
  @@index([expiresAt])
  @@index([bookingId])
}

// ── Membership tiers (K Circle) ───────────────────────────────────────────────
// Status-based tiers earned from rolling 12-month spend. Higher tiers earn
// loyalty points faster (pointsMultiplierBps) and unlock perks/early access.
// Editable by the owner; seeded with sensible defaults on first use.
model MembershipTier {
  id                  String   @id @default(cuid())
  key                 String   @unique // stable: member | silver | gold | platinum
  name                String
  minSpendPence       Int      @default(0) // rolling 12-month spend to reach this tier
  pointsMultiplierBps Int      @default(100) // 100 = 1.0×, 150 = 1.5×, 200 = 2.0×
  birthdayBonusPoints Int      @default(0)
  earlyAccessHours    Int      @default(0) // priority booking window (future use)
  retailDiscountPct   Int      @default(0) // optional member retail discount (kept 0 by default)
  perks               String[] @default([]) // marketing bullet points
  color               String? // hex for the tier badge
  sortOrder           Int      @default(0)
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
}

// ── Referrals ─────────────────────────────────────────────────────────────
// One row per referred friend. Rewards (both sides get £25 / 2500 pts) fire
// when the friend's FIRST treatment of ≥ £100 completes.
model Referral {
  id            String  @id @default(cuid())
  referrer      Client  @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referrerId    String
  // The referred friend, linked when they sign up via the code.
  referred      Client? @relation("ReferralReceived", fields: [referredId], references: [id], onDelete: SetNull)
  referredId    String? @unique // a client can only be referred once
  referredEmail String? // captured at sign-up for visibility

  status      ReferralStatus @default(JOINED)
  qualifiedAt DateTime? // friend's first ≥£100 treatment completed
  rewardedAt  DateTime? // both sides credited

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referrerId])
  @@index([status])
}

// ── Client reviews (own architecture; optional sync to Google Business) ──────
model Review {
  id          String     @id @default(cuid())
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  booking     Booking?   @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  bookingId   String?
  // The clinician the review is about (for staff gamification later).
  clinician   AdminUser? @relation("ClinicianReviews", fields: [clinicianId], references: [id], onDelete: SetNull)
  clinicianId String?

  status  ReviewStatus  @default(PENDING)
  channel ReviewChannel @default(EMAIL)
  // Unguessable token for the public "leave a review" link.
  token   String        @unique @default(cuid())

  rating         Int? // 1–5, set when the client submits
  title          String?
  body           String?
  treatmentTitle String? // snapshot of what was treated
  // Explicit client consent to feature this review publicly with their first
  // name. Without it we never show the name (reviews still need to be 5★ with a
  // written response to appear on the site at all).
  displayConsent Boolean @default(false)

  // Moderation + publication.
  moderatedBy        String?
  moderatedAt        DateTime?
  // Google Business sync (dummy/inert until credentials supplied).
  googleReviewId     String?
  pushedToGoogleAt   DateTime?
  // If they clicked through to leave it directly on Google instead.
  redirectedToGoogle Boolean   @default(false)

  requestedAt DateTime?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([clinicianId])
  @@index([rating])
}

// Google Business Profile reviews imported via the My Business API. Stored
// separately from Review (which requires a Client) because the reviewer is an
// external Google user. Powers the in-admin Google review list + replies.
model GoogleReview {
  id              String    @id @default(cuid())
  // Full review resource name: accounts/{a}/locations/{l}/reviews/{r} (unique).
  googleName      String    @unique
  reviewerName    String?
  reviewerPhoto   String?
  starRating      Int // 1–5 (mapped from Google's ONE..FIVE enum)
  comment         String?
  createTime      DateTime?
  updateTime      DateTime?
  // Our reply (mirrored from Google so the admin shows the live state).
  replyComment    String?
  replyUpdateTime DateTime?
  importedAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([starRating])
  @@index([createTime])
}

// ── SEO command centre ──────────────────────────────────────────────────────
// Per-path SEO overrides, editable in the admin and merged over code defaults.
model PageSeo {
  id           String   @id @default(cuid())
  path         String   @unique // e.g. "/laser-hair-removal"
  title        String?
  description  String?
  canonical    String?
  focusKeyword String?
  ogImage      String?
  noindex      Boolean  @default(false)
  jsonLd       Json? // optional custom JSON-LD injected on the page
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── K Clinics Academy (training sub-brand) ──────────────────────────────────
// Premium clinician training. Theory on Thinkific, scheduled practical days,
// VTCT exam administered in-house. Ofqual-regulated + CPD. Catalogue is fully
// CRM-managed; trainees use a separate account/portal.

// ── ClinicOS multi-tenancy (Ring 0) ──────────────────────────────────────────
// A licensed clinic on the platform. K Clinics is tenant #1. Academy tables carry
// a nullable tenantId, backfilled to the default tenant; query scoping + RLS land
// in Ring 1. See docs/PLATFORM_SAAS_PLAN.md (v0.4, BLD-35).
model Tenant {
  id        String   @id @default(cuid())
  slug      String   @unique // url-safe key, e.g. "kclinics"
  name      String
  host      String?  @unique // primary hostname for resolution (e.g. kclinics.co.uk)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AcademyStudent {
  id             String    @id @default(cuid())
  tenantId       String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  firstName      String
  lastName       String?
  email          String    @unique
  dob            DateTime?
  ageDeclaredAt  DateTime? // confirmed 16+ at signup
  goals          String?
  onboardedAt    DateTime?
  phone          String?
  passwordHash   String?
  portalActive   Boolean   @default(false)
  lastLoginAt    DateTime?
  resetTokenHash String?
  resetTokenExp  DateTime?
  notes          String?
  xp             Int       @default(0) // gamification points (earned across the academy)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  enrolments       Enrolment[]
  lessonProgress   LessonProgress[]
  quizAttempts     QuizAttempt[]
  practiceAttempts PracticeAttempt[]
  pointEvents      PointEvent[]
  badges           StudentBadge[]
  dailyActivity    DailyActivity[]

  @@index([createdAt])
  @@index([xp])
  @@index([tenantId])
}

model Course {
  id             String   @id @default(cuid())
  tenantId       String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  slug           String   @unique
  title          String
  level          String? // e.g. "Level 4"
  summary        String? // one-liner for cards
  description    String? // long form (markdown-ish)
  pricePence     Int      @default(0)
  depositPence   Int? // optional deposit to reserve a place
  durationText   String? // e.g. "2 practical days + online theory + exam"
  format         String? // e.g. "Blended: Thinkific theory + practical + VTCT exam"
  accreditations String[] @default([]) // OFQUAL | VTCT | CPD
  outcomes       String[] @default([]) // "what you'll learn" bullets
  objectives     String[] @default([]) // course-level learning goals/objectives
  welcome        String? // intro shown when a student first opens the course
  prerequisites  String?
  thinkificUrl   String? // theory platform link (shown in trainee portal)
  heroImage      String?
  featured       Boolean  @default(false)
  active         Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cohorts       Cohort[]
  enrolments    Enrolment[]
  modules       CourseModule[]
  liveClasses   LiveClass[]
  examQuestions ExamQuestion[]
  pastPapers    PastPaper[]

  @@index([active, order])
  @@index([tenantId])
}

// ── Native LMS (replaces external Thinkific theory) ──────────────────────────

model CourseModule {
  id        String   @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  title     String
  summary   String?
  order     Int      @default(0)
  lessons   Lesson[]
  quiz      Quiz?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, order])
  @@index([tenantId])
}

model Lesson {
  id          String           @id @default(cuid())
  tenantId    String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  module      CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId    String
  title       String
  order       Int              @default(0)
  durationMin Int?
  videoUrl    String? // YouTube watch/embed URL, or a search link (pre-test explainer)
  imageUrl    String?
  body        String           @db.Text // markdown-ish lesson content
  keyPoints   String[]         @default([])
  objectives  String[]         @default([]) // "by the end you will…" shown at lesson start
  studyTips   String[]         @default([]) // exam tips / memory aids surfaced in-lesson
  homework    String? // assignment to complete after the lesson (markdown)
  examRefs    String[]         @default([]) // real exam/syllabus references this maps to
  steps       Json? // authored bite-size flow [{kind:'teach'|'say'|'ask', …}]; when null the player auto-chunks `body`
  minSeconds  Int? // minimum dwell time before the lesson can be marked complete
  citations   Json? // [{ label, url }]
  resources   Json? // [{ label, url }]
  progress    LessonProgress[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([moduleId, order])
  @@index([tenantId])
}

model Quiz {
  id        String         @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  module    CourseModule   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId  String         @unique
  title     String
  passMark  Int            @default(70) // percentage required to pass
  questions QuizQuestion[]
  attempts  QuizAttempt[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([tenantId])
}

model QuizQuestion {
  id          String  @id @default(cuid())
  tenantId    String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  quiz        Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId      String
  order       Int     @default(0)
  prompt      String  @db.Text
  type        String  @default("SINGLE") // SINGLE | MULTI | TRUEFALSE
  options     Json // [string]
  correct     Json // [number] (0-based indices)
  explanation String? @db.Text
  tip         String? // optional hint surfaced to help the learner (Duolingo-style)
  imageUrl    String?

  @@index([quizId, order])
  @@index([tenantId])
}

model LessonProgress {
  id           String         @id @default(cuid())
  tenantId     String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  student      AcademyStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  lesson       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId     String
  completedAt  DateTime       @default(now())
  secondsSpent Int            @default(0) // total dwell time recorded for this lesson

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@index([tenantId])
}

model QuizAttempt {
  id        String         @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  student   AcademyStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  quiz      Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  quizId    String
  scorePct  Int
  passed    Boolean
  answers   Json?
  createdAt DateTime       @default(now())

  @@index([studentId, quizId])
  @@index([tenantId])
}

// ── Exam practice (test-anytime question bank + historic papers) ─────────────

model ExamQuestion {
  id          String   @id @default(cuid())
  tenantId    String? // ClinicOS multi-tenant (Ring 0)
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseId    String?
  topic       String? // e.g. "Anatomy & Physiology"
  difficulty  String   @default("STANDARD") // FOUNDATION | STANDARD | STRETCH
  examBoard   String? // VTCT | OFQUAL | CPD …
  prompt      String   @db.Text
  type        String   @default("SINGLE") // SINGLE | MULTI | TRUEFALSE
  options     Json // [string]
  correct     Json // [number] (0-based indices)
  explanation String?  @db.Text
  tip         String? // optional hint (Duolingo-style)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId, active])
  @@index([topic])
  @@index([tenantId])
}

model PastPaper {
  id          String   @id @default(cuid())
  tenantId    String? // ClinicOS multi-tenant (Ring 0)
  course      Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  courseId    String?
  title       String
  examBoard   String?
  year        Int?
  description String?  @db.Text // what the paper covers / how to use it
  fileUrl     String? // link to the PDF / specimen paper
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId, active, order])
  @@index([tenantId])
}

model PracticeAttempt {
  id        String         @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0)
  student   AcademyStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  courseId  String? // course the practice was drawn from (no FK constraint needed)
  topic     String?
  total     Int
  correct   Int
  scorePct  Int
  createdAt DateTime       @default(now())

  @@index([studentId])
  @@index([courseId])
  @@index([tenantId])
}

// ── Gamification (XP ledger + badges) ────────────────────────────────────────

model PointEvent {
  id        String         @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0)
  student   AcademyStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  kind      String // LESSON | QUIZ | PRACTICE | BADGE | BONUS
  points    Int
  courseId  String?
  note      String?
  createdAt DateTime       @default(now())

  @@index([studentId, createdAt])
  @@index([tenantId])
}

model StudentBadge {
  id        String         @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0)
  student   AcademyStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  badgeKey  String // matches a key in lib/academy-gamification BADGES
  awardedAt DateTime       @default(now())

  @@unique([studentId, badgeKey])
  @@index([studentId])
  @@index([tenantId])
}

// Daily tasks + the "beauty box" (a Duolingo-style chest unlocked by doing a few
// tasks in a day). One row per student per UTC day.
model DailyActivity {
  id        String         @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0)
  student   AcademyStudent @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  day       String // YYYY-MM-DD (UTC)
  tasks     Int            @default(0)
  boxOpened Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([studentId, day])
  @@index([studentId])
  @@index([tenantId])
}

model LiveClass {
  id          String    @id @default(cuid())
  tenantId    String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  title       String
  startAt     DateTime
  endAt       DateTime?
  joinUrl     String? // Google Meet link
  trainer     String?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([courseId, startAt])
  @@index([tenantId])
}

enum CohortStatus {
  OPEN
  FULL
  CLOSED
}

model Cohort {
  id        String       @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  startAt   DateTime
  endAt     DateTime?
  capacity  Int          @default(8)
  location  String?
  trainer   String?
  status    CohortStatus @default(OPEN)
  notes     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  enrolments Enrolment[]

  @@index([courseId, startAt])
  @@index([tenantId])
}

enum EnrolmentStatus {
  APPLIED // applied/enquired — awaiting staff review
  OFFERED // place offered, awaiting payment
  PAID // paid (full or deposit)
  ENROLLED // confirmed on a cohort
  COMPLETED // course + exam completed
  CANCELLED
}

model Enrolment {
  id        String          @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId  String
  cohort    Cohort?         @relation(fields: [cohortId], references: [id], onDelete: SetNull)
  cohortId  String?
  student   AcademyStudent? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  studentId String?

  // Applicant details captured at enquiry (before an account may exist).
  applicantName   String
  applicantEmail  String
  applicantPhone  String?
  experience      String? // free-text background / qualifications
  financeInterest Boolean @default(false) // interested in Clearpay financing

  status     EnrolmentStatus @default(APPLIED)
  pricePence Int             @default(0)
  paidPence  Int             @default(0)
  notes      String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([status])
  @@index([courseId])
  @@index([applicantEmail])
  @@index([tenantId])
}

// ── Post-treatment follow-up questionnaire ──────────────────────────────────
// Sent ~1 week after a completed treatment ("How is your skin today?"). If the
// client reports a concern, a follow-up Task is auto-created for the team.
model FollowUp {
  id             String    @id @default(cuid())
  booking        Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId      String    @unique
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String
  treatmentTitle String
  token          String    @unique @default(cuid())
  sentAt         DateTime  @default(now())
  respondedAt    DateTime?
  sentiment      String? // 'great' | 'ok' | 'concerned'
  concern        Boolean   @default(false)
  comment        String?
  taskId         String? // the admin task created when a concern is reported
  createdAt      DateTime  @default(now())

  @@index([clientId])
  @@index([respondedAt])
}

// ── AI Consultation ("K Vision") ────────────────────────────────────────────
// Account-gated photo analysis → catalogue-bound treatment plan. Findings are
// special-category data (encrypted with the keyring). Recommendations only ever
// reference real, priced catalogue items so a plan is always margin-positive.
model AiAnalysis {
  id               String    @id @default(cuid())
  client           Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId         String
  areas            String[]  @default([]) // skin | teeth | hair | body
  model            String? // which Claude model produced it
  status           String    @default("complete") // complete | refused | error
  confidence       Float?
  needsExpert      Boolean   @default(false)
  budgetPence      Int?
  findingsEnc      String? // encrypted JSON: [{area,label,note,severity}]
  planJson         Json? // resolved plan: [{slug,title,price,reason}] (non-clinical)
  recommendedSlugs String[]  @default([])
  summary          String? // short, non-clinical headline for cards
  tokensIn         Int?
  tokensOut        Int?
  consentAt        DateTime?
  storeImages      Boolean   @default(true)
  createdAt        DateTime  @default(now())

  images AiAnalysisImage[]

  @@index([clientId, createdAt])
}

model AiAnalysisImage {
  id         String     @id @default(cuid())
  analysis   AiAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  analysisId String
  area       String?
  dataEnc    String // encrypted, downscaled image data URL
  createdAt  DateTime   @default(now())

  @@index([analysisId])
}

// ── Careers — live vacancies (admin-managed) + applications ──────────────────
model Vacancy {
  id          String   @id @default(cuid())
  tenantId    String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  slug        String   @unique
  title       String
  department  String? // Clinical · Front of house · Management …
  location    String? // defaults to the clinic locality
  type        String? // Full-time · Part-time · Contract · Bank
  summary     String? // one-line for the list
  description String? // long form (markdown-ish)
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications JobApplication[]

  @@index([active, order])
  @@index([tenantId])
}

model JobApplication {
  id        String   @id @default(cuid())
  tenantId  String? // ClinicOS multi-tenant (Ring 0); backfilled to the K Clinics tenant
  vacancy   Vacancy? @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
  vacancyId String?
  roleTitle String // snapshot (so it survives a deleted vacancy)
  name      String
  email     String
  phone     String?
  coverNote String?
  cvUrl     String?
  status    String   @default("NEW") // NEW · REVIEWING · INTERVIEW · OFFERED · REJECTED · HIRED
  createdAt DateTime @default(now())

  @@index([status])
  @@index([vacancyId])
  @@index([tenantId])
}

// ── Gift vouchers (e-gift cards) ─────────────────────────────────────────────
model GiftVoucher {
  id                    String    @id @default(cuid())
  code                  String    @unique
  amountPence           Int
  balancePence          Int
  purchaserName         String
  purchaserEmail        String
  recipientName         String?
  recipientEmail        String?
  message               String?
  design                String? // chosen card theme id (lib/gift-card-themes)
  packageSlug           String? // earmarked giftable package (Product slug); null = open-value card
  packageName           String? // package name snapshot for the card/receipt
  deliverAt             DateTime? // scheduled delivery date (null = immediate)
  delivered             Boolean   @default(false)
  status                String    @default("PENDING") // PENDING | ACTIVE | REDEEMED | CANCELLED
  // Optional paid physical-card upgrade — a printed card posted to the recipient.
  physical              Boolean   @default(false)
  physicalFeePence      Int       @default(0) // extra charged for the printed card
  fulfillment           String    @default("none") // none | unfulfilled | posted
  shipName              String?
  shipLine1             String?
  shipLine2             String?
  shipCity              String?
  shipPostcode          String?
  postedAt              DateTime?
  stripePaymentIntentId String?   @unique
  expiresAt             DateTime?
  claimedByClientId     String?
  claimedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
  @@index([delivered, deliverAt])
  @@index([claimedByClientId])
}

// Footer newsletter sign-ups. Separate from Client — these are marketing
// subscribers who consented explicitly at the point of sign-up. Every record
// carries the consent timestamp and an unsubscribe token (GDPR/PECR).
model NewsletterSubscriber {
  id          String   @id @default(cuid())
  email       String   @unique
  active      Boolean  @default(true)
  source      String? // e.g. "footer"
  consentedAt DateTime @default(now())
  unsubToken  String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

// Before/after gallery cases uploaded by staff in the CRM. Each holds a real
// BEFORE and AFTER image (stored as bytes in the DB — no external blob store).
// Only shown publicly when `published` is true AND consent is confirmed.
model GalleryItem {
  id            String   @id @default(cuid())
  category      String // e.g. "Veneers", "Botox"
  treatmentSlug String? // optional link target on the site
  caption       String?
  beforeImage   Bytes
  beforeType    String   @default("image/jpeg")
  afterImage    Bytes
  afterType     String   @default("image/jpeg")
  published     Boolean  @default(false) // "show on the website" toggle
  consent       Boolean  @default(false) // client gave written consent to publish
  order         Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([published, order])
}

// Append-only security/auth telemetry — powers the admin Security centre and
// the brute-force lockout logic (source of truth; Redis is an optional fast
// counter layered on top via lib/security/rate-limit).
model SecurityEvent {
  id         String   @id @default(cuid())
  type       String // LOGIN_OK | LOGIN_FAIL | LOCKOUT | RATE_LIMITED | CAPTCHA_FAIL | TWOFA_FAIL | TWOFA_OK | TWOFA_ENABLED | TWOFA_DISABLED | UNLOCK
  portal     String // admin | client | academy
  identifier String? // attempted email (lowercased)
  ip         String?
  userAgent  String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([type, createdAt])
  @@index([identifier, createdAt])
  @@index([ip, createdAt])
  @@index([createdAt])
}

// Promotional discount codes — two kinds:
//  • UNIVERSAL: one code anyone can use (e.g. "K10SUMMERREADY", 10% off in June)
//  • PERSONAL:  a unique code generated per campaign recipient, tied to their email
model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique // stored uppercased
  kind           String    @default("UNIVERSAL") // UNIVERSAL | PERSONAL
  discountType   String    @default("PERCENT") // PERCENT | FIXED
  percent        Int? // when PERCENT (1–100)
  amountPence    Int? // when FIXED
  treatmentSlugs String[]  @default([]) // empty = all treatments
  minSpendPence  Int?
  maxRedemptions Int? // null = unlimited (per code)
  redeemedCount  Int       @default(0)
  oncePerClient  Boolean   @default(true)
  assignedEmail  String? // PERSONAL: locks the code to a recipient
  campaignId     String? // links to the Campaign that generated it
  label          String? // internal promo name
  startsAt       DateTime?
  expiresAt      DateTime?
  active         Boolean   @default(true)
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  redemptions PromoRedemption[]

  @@index([active, expiresAt])
  @@index([campaignId])
  @@index([assignedEmail])
}

model PromoRedemption {
  id             String    @id @default(cuid())
  promo          PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  promoCodeId    String
  clientId       String?
  email          String?
  bookingId      String?
  amountOffPence Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([promoCodeId])
  @@index([clientId])
}

// In-house live chat: a visitor conversation + its messages. No third-party
// processor — everything stays in our database. Visitors are identified by an
// unguessable token stored in their browser; staff reply from the CRM.
model ChatConversation {
  id                String    @id @default(cuid())
  token             String    @unique @default(cuid())
  visitorName       String?
  visitorEmail      String?
  clientId          String? // if a signed-in client started it
  status            String    @default("OPEN") // OPEN | CLOSED
  mode              String    @default("AI") // AI | STAFF — who is answering
  staffUnread       Int       @default(0) // messages awaiting staff
  page              String? // path the chat was opened from
  lastMessageAt     DateTime  @default(now())
  // Presence: when the visitor was last active (each poll/send refreshes it).
  // Drives the "email the reply only once they've left" follow-up logic.
  lastVisitorSeenAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  messages ChatMessage[]

  @@index([status, lastMessageAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         String // VISITOR | STAFF | AI
  author         String? // staff email, when sender = STAFF (internal)
  // Visitor-facing identity for a staff reply, sourced from the responder's own
  // logged-in account (AdminUser). Null name = show as "KClinics" (OWNER/ADMIN,
  // who are presented as the clinic, not by name).
  authorName     String? // first name from their account
  authorTitle    String? // their account title, e.g. "Aesthetic Doctor"
  authorId       String? // their AdminUser id — deep-links to /team#m-<id>
  // Whether they've opted into a public team profile (so we link the name).
  authorPublic   Boolean          @default(false)
  body           String           @db.Text
  // 'chat' (web widget) or 'email' (sent to / received from the visitor by email).
  via            String           @default("chat")
  // When a staff/AI reply was emailed to the visitor (null = not emailed).
  emailedAt      DateTime?
  // Inbound email Message-ID, to thread replies & de-duplicate webhook deliveries.
  externalId     String?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@index([externalId])
}

// ── Blog / Journal posts (DB-backed CMS) ────────────────────────────────────
// Admin-managed articles for /journal. Native curated articles (lib/articles.ts)
// still render as a fallback for any slug not present here, so nothing vanishes.
enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id              String     @id @default(cuid())
  slug            String     @unique
  title           String
  excerpt         String?
  metaDescription String?
  content         String // HTML body (rendered from `blocks`; kept for public render + SEO)
  blocks          Json? // structured block-editor content (source of truth when present)
  category        String? // Skin | Laser | Injectables | Dentistry | Wellbeing
  tags            String[]   @default([])
  keywords        String[]   @default([])
  related         String[]   @default([]) // treatment slugs mentioned (for CTAs)
  coverImage      String? // image URL/path (optional → generative art fallback)
  readMinutes     Int        @default(5)
  status          PostStatus @default(DRAFT)
  source          String? // 'wordpress' | 'native' | null (admin-authored)
  authorName      String?    @default("The KClinics team")
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status, publishedAt])
}

// ── Site CMS ──────────────────────────────────────────────────────────────────
// Global business variables (contact, social, hours, booking, brand text,
// announcement bar, navigation). Single source of truth, overriding lib/site.ts
// defaults. Edited from Admin → Site. One singleton row (id = "singleton").
model SiteConfig {
  id        String   @id @default("singleton")
  data      Json // full SiteConfig shape (see lib/site-config.ts)
  updatedAt DateTime @updatedAt
  updatedBy String?

  revisions SiteConfigRevision[]
}

// CMS pages: an ordered list of modular sections (see lib/sections.ts). A page
// can override an existing editorial route by `path`, or create a brand-new one.
// draft = work in progress; published = live (null until first publish).
model Page {
  id          String    @id @default(cuid())
  path        String    @unique
  title       String?
  draft       Json // Section[]
  published   Json? // Section[] (null = route shows its coded default)
  status      String    @default("DRAFT") // DRAFT | PUBLISHED
  publishAt   DateTime? // scheduled go-live (null = immediate)
  unpublishAt DateTime? // scheduled take-down (null = never)
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  revisions PageRevision[]

  @@index([status])
}

// Reusable/global section: authored once, referenced from many pages via a
// section of type "ref" ({ refId }). Editing it updates every page that uses it.
model GlobalSection {
  id        String   @id @default(cuid())
  name      String
  type      String // a section type from lib/sections.ts
  data      Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model PageRevision {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  data      Json // Section[] snapshot
  label     String?
  createdAt DateTime @default(now())
  createdBy String?

  @@index([pageId, createdAt])
}

// Per-treatment marketing content override. Keyed by Treatment.slug; any field
// set here replaces the static copy in lib/treatments.ts on the /[slug] page.
// Edited from Admin → Services → a service's "Edit page content".
model TreatmentContent {
  slug            String   @id
  title           String?
  tagline         String?
  eyebrow         String?
  intro           String?
  metaTitle       String?
  metaDescription String?
  keywords        String[] @default([])
  priceFrom       String?
  benefits        Json? // { title, text }[]
  process         Json? // { title, text }[]
  faqs            Json? // { q, a }[]
  facts           Json? // { label, value }[]
  related         String[] @default([])
  updatedAt       DateTime @updatedAt
  updatedBy       String?
}

// Uploaded media (Vercel Blob). The library powering image pickers across the
// admin (journal covers, page builder sections, etc.).
model MediaAsset {
  id        String   @id @default(cuid())
  url       String // public Blob URL
  pathname  String // Blob pathname (for deletion)
  filename  String
  alt       String?
  mime      String?
  size      Int?
  width     Int?
  height    Int?
  folder    String?  @default("general")
  createdAt DateTime @default(now())
  createdBy String?

  @@index([createdAt])
}

model SiteConfigRevision {
  id        String     @id @default(cuid())
  configId  String
  config    SiteConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  data      Json // snapshot taken at each save (for rollback)
  label     String?
  createdAt DateTime   @default(now())
  createdBy String?

  @@index([configId, createdAt])
}

// ── Dynamic QR codes ─────────────────────────────────────────────────────────
// Internal QR tool: each code is a short, stable slug served at /qr/{code} that
// 302-redirects to an editable destination — so a printed/in-clinic code can be
// re-pointed without reprinting. Scans are logged for lightweight analytics
// (coarse device/referer/country only — no IP or personal data stored).
model QrCode {
  id          String   @id @default(cuid())
  code        String   @unique // slug used in the public /qr/{code} URL
  label       String // internal name, e.g. "Reception poster"
  destination String // current redirect target (editable any time)
  active      Boolean  @default(true)
  notes       String?
  scanCount   Int      @default(0) // denormalised running total for quick display
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scans QrScan[]

  @@index([active])
}

model QrScan {
  id        String   @id @default(cuid())
  qr        QrCode   @relation(fields: [qrCodeId], references: [id], onDelete: Cascade)
  qrCodeId  String
  at        DateTime @default(now())
  device    String? // mobile | tablet | desktop
  referer   String?
  country   String? // coarse, from edge header when available
  userAgent String?

  @@index([qrCodeId, at])
}

// ── URL redirects ────────────────────────────────────────────────────────────
// Admin-managed 301/302 redirects so old WordPress URLs (and any printed/static
// QR destinations) keep resolving on the new site — protects SEO + inbound links.
// Read by the edge middleware via /api/redirects (cached).
model Redirect {
  id        String   @id @default(cuid())
  fromPath  String   @unique // site-relative path, e.g. "/old-page"
  toUrl     String // destination (relative path or absolute URL)
  code      Int      @default(301) // 301 permanent | 302 temporary
  active    Boolean  @default(true)
  note      String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

// ── A/B testing ──────────────────────────────────────────────────────────────
// Content experiments (e.g. competing landing-page headlines). Visitors are
// split by weight into a variant (sticky via a cookie); we count exposures and
// conversions (CTA clicks) to find the winner. Aggregate counters only.
enum AbStatus {
  DRAFT
  RUNNING
  STOPPED
}

model AbTest {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique // used by the page section + cookie key
  status    AbStatus @default(DRAFT)
  goal      String   @default("cta_click")
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants AbVariant[]
}

model AbVariant {
  id          String  @id @default(cuid())
  test        AbTest  @relation(fields: [testId], references: [id], onDelete: Cascade)
  testId      String
  key         String // A | B | C …
  label       String
  weight      Int     @default(1)
  headline    String?
  subhead     String?
  ctaLabel    String?
  ctaHref     String?
  exposures   Int     @default(0)
  conversions Int     @default(0)

  @@unique([testId, key])
}

// ── Behaviour analytics: heatmaps + session replay ───────────────────────────
// First-party, consent-gated (analytics). Inputs are masked in replay; only
// coarse interaction data is stored — no keystrokes, no personal data.
model ReplaySession {
  id         String        @id @default(cuid())
  sessionKey String        @unique // client-generated per visit
  path       String // entry path
  device     String?
  durationMs Int           @default(0)
  eventCount Int           @default(0)
  startedAt  DateTime      @default(now())
  lastAt     DateTime      @default(now())
  chunks     ReplayChunk[]

  @@index([startedAt])
}

model ReplayChunk {
  id        String        @id @default(cuid())
  session   ReplaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  seq       Int
  events    Json // batch of rrweb events
  createdAt DateTime      @default(now())

  @@index([sessionId, seq])
}

model HeatmapEvent {
  id        String   @id @default(cuid())
  path      String
  type      String // click | rage | scroll
  xPct      Int      @default(0) // 0–1000 (tenths of a %) of viewport width
  yPct      Int      @default(0) // 0–1000 of full page height
  scrollPct Int      @default(0) // max scroll depth for 'scroll' rows
  at        DateTime @default(now())

  @@index([path, type])
  @@index([at])
}

// ── Audience segments ────────────────────────────────────────────────────────
// Reusable, rule-based client segments for campaign + email targeting. Rules are
// evaluated against Client fields (gender, source, tags, opt-in, recency).
model Segment {
  id             String    @id @default(cuid())
  name           String
  description    String?
  rules          Json // { gender?, source?, tag?, lapsedDays?, optInOnly?, visited? }
  metaAudienceId String? // Meta Custom Audience id once synced (marketing API #3)
  metaSyncedAt   DateTime? // last successful push to Meta
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ── Consent forms (DocuSign-grade e-signature) ───────────────────────────────
// Editable per-category templates; each signature is captured immutably with a
// content hash, timestamps, IP and the exact text version signed. Held under the
// Health Data API (AES-256-GCM + integrity HMAC).
model ConsentTemplate {
  id               String   @id @default(cuid())
  key              String   @unique // general | laser | injectables | facials | dental | photo_opt_out
  title            String
  category         String   @default("general")
  version          Int      @default(1)
  bodyMd           String // consent wording (markdown)
  acknowledgements String[] @default([]) // required tick statements
  active           Boolean  @default(true)
  // Assignment: which treatments this form applies to. A service slug match wins
  // over a group match; if a treatment matches nothing, the engine falls back to
  // the built-in category logic. Both default empty (additive, non-destructive).
  serviceSlugs     String[] @default([]) // specific treatment slugs (most specific)
  serviceGroups    String[] @default([]) // marketing groups, e.g. "Laser & Skin"
  updatedBy        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum ConsentStatus {
  PENDING
  SIGNED
  DECLINED
  EXPIRED
}

// A request to sign a specific form for a specific client/appointment. Opens via
// an unguessable token on a phone or the clinic iPad (no login needed).
model ConsentRequest {
  id              String        @id @default(cuid())
  token           String        @unique @default(cuid())
  clientId        String
  bookingId       String?
  templateKey     String
  title           String
  kind            String        @default("treatment") // treatment | photo_opt_out
  status          ConsentStatus @default(PENDING)
  signedConsentId String?
  createdBy       String?
  createdAt       DateTime      @default(now())
  expiresAt       DateTime?

  @@index([bookingId])
  @@index([clientId, status])
}

// The immutable signed record. Never updated — a correction is a new record.
model SignedConsent {
  id              String   @id @default(cuid())
  clientId        String
  bookingId       String?
  templateKey     String
  templateVersion Int
  title           String
  kind            String   @default("treatment")
  declined        Boolean  @default(false)
  signerName      String
  cipher          String // encrypted JSON: body, ticks, signature image, timestamps, IP, UA
  integrityHash   String // HMAC binding cipher to metadata
  contentHash     String // SHA-256 of the canonical signed payload (certificate id)
  signedAt        DateTime @default(now())
  ip              String?
  createdAt       DateTime @default(now())

  @@index([bookingId])
  @@index([clientId])
}

// ── Pre-treatment "before" photos (laser) ────────────────────────────────────
// Captured live in-app on the clinic device, encrypted at rest under the Health
// Data API. Never written to the clinician's device. Intimate areas are
// prohibited (clinician attestation required at capture).
model BeforePhoto {
  id          String   @id @default(cuid())
  bookingId   String
  clientId    String
  area        String? // non-intimate treatment area label
  dataEnc     String // encrypted, downscaled image data URL
  capturedBy  String // clinician email
  attestation Boolean  @default(false) // confirmed: non-intimate area, consented
  createdAt   DateTime @default(now())

  @@index([bookingId])
}

// ── Retail products (Shopify-style) ──────────────────────────────────────────
// Physical/retail products sold through the site (e.g. skincare). Separate from
// clinical consumables (StockItem). Age-restricted items require an 18+ check at
// checkout (per-product toggle); most products are not age-gated.
enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Product {
  id                String        @id @default(cuid())
  slug              String        @unique
  name              String
  description       String?
  brand             String?
  category          String?
  pricePence        Int           @default(0)
  compareAtPence    Int? // "was" price for sale display
  costPence         Int? // cost of goods (margin)
  sku               String?
  barcode           String?
  images            String[]      @default([])
  status            ProductStatus @default(DRAFT)
  ageRestricted     Boolean       @default(false) // requires 18+ at checkout
  trackInventory    Boolean       @default(true)
  stockQty          Int           @default(0)
  lowStockThreshold Int           @default(5)
  createdBy         String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([category])
}

// ── Retail orders (product storefront) ───────────────────────────────────────
enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

model Order {
  id                    String      @id @default(cuid())
  number                String      @unique // human-friendly reference
  clientId              String?
  email                 String
  name                  String
  phone                 String?
  // Fulfilment: ship to an address, or collect in clinic.
  method                String      @default("ship") // ship | collect
  shipName              String?
  shipLine1             String?
  shipLine2             String?
  shipCity              String?
  shipPostcode          String?
  subtotalPence         Int
  shippingPence         Int         @default(0)
  giftCardCode          String?
  giftCardPence         Int         @default(0)
  totalPence            Int
  ageVerified           Boolean     @default(false)
  status                OrderStatus @default(PENDING)
  fulfillment           String      @default("unfulfilled") // unfulfilled | shipped | collected
  trackingNote          String?
  stripePaymentIntentId String?     @unique
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id            String  @id @default(cuid())
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId       String
  productId     String?
  name          String
  sku           String?
  unitPence     Int
  qty           Int
  ageRestricted Boolean @default(false)
}

// ─────────────────────────────────────────────────────────────────────────────
// Day-close — the end-of-day clinic shutdown record. One per location per
// business day. Captures the financial reconciliation (expected vs counted
// card & cash, with variance), the stock take, and the full closedown
// checklist (cleaning, equipment/fire safety, security & lock-up, maintenance).
// The free-form `payload` holds the complete snapshot of every step's answers
// so the close-out report is fully reconstructable. The configurable task
// template + reminder schedule live in the Setting key-value store, not here.
// ─────────────────────────────────────────────────────────────────────────────
model DayClose {
  id           String         @id @default(cuid())
  location     Location?      @relation(fields: [locationId], references: [id], onDelete: SetNull)
  locationId   String?
  businessDate DateTime // the day being closed (local midnight)
  status       DayCloseStatus @default(IN_PROGRESS)

  // Financial reconciliation — all amounts in pence.
  expectedCardPence Int  @default(0) // card takings computed from charges & paid orders
  countedCardPence  Int? // operator-confirmed card total (terminal Z-report)
  floatOpenPence    Int  @default(0) // opening cash float
  cashCountedPence  Int? // cash counted in the drawer at close
  cashTakingsPence  Int? // cash takings recorded for the day
  variancePence     Int? // (counted card + cash takings) − expected

  // Completeness of the closedown checklist (0–100) and full answer snapshot.
  checklistDone  Int   @default(0) // items completed
  checklistTotal Int   @default(0) // items required
  payload        Json?

  notes       String?
  startedBy   String // staff email
  startedAt   DateTime  @default(now())
  completedBy String?
  completedAt DateTime?

  @@index([businessDate])
  @@index([locationId, businessDate])
  @@index([status])
}

enum DayCloseStatus {
  IN_PROGRESS
  COMPLETED
}

// ─────────────────────────────────────────────────────────────────────────────
// Build & Issues board — a live work tracker separate from staff to-dos (Task).
// Staff report problems (with screenshots + urgency); items are triaged on a
// kanban, allocated to Claude or staff, optionally bridged to GitHub issues, and
// every change is recorded as a BuildEvent (the live audit trail).
// ─────────────────────────────────────────────────────────────────────────────
enum BuildType {
  ERROR
  TASK
  IDEA
  REVIEW
  AUDIT
}

enum BuildStatus {
  TRIAGE
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  SHIPPED
  CLOSED
  CANCELLED
}

enum BuildUrgency {
  P0
  P1
  P2
  P3
}

model BuildItem {
  id              String            @id @default(cuid())
  // Stable human-readable reference for tracing/search: standalone items are
  // BLD-<seq>; items created/seeded inside a project branch from the project's
  // ref (PRJ-3 → PRJ-3.1). Immutable once assigned (an item moved into a
  // project later keeps its BLD ref). No @unique — the no-data-loss deploy gate
  // can't add unique constraints; uniqueness is structural (lib/task-refs.ts).
  seq             Int               @default(autoincrement())
  ref             String?
  type            BuildType         @default(TASK)
  title           String
  detail          String?           @db.Text
  status          BuildStatus       @default(TRIAGE)
  urgency         BuildUrgency      @default(P2)
  assignee        String            @default("claude") // 'claude' or a staff email
  reportedBy      String? // staff email who logged it
  pageUrl         String? // where the problem was found
  screenshots     String[]          @default([])
  attachments     String[]          @default([]) // images + videos attached to the task (Vercel Blob URLs)
  blocker         String? // current blocker note (when status = BLOCKED)
  githubUrl       String?
  githubNumber    Int?
  isPublic        Boolean           @default(false) // surfaces on a future public roadmap
  // Prioritisation (persisted so ideas can be scored/triaged in-app, not just in code).
  value           Int? // business worth 1–10
  effort          Int? // build cost 1–10
  // Effort/usage telemetry: time is auto-derived (startedAt → shippedAt); tokens
  // are Claude's best-effort self-report. estCompleteAt is an ETA Claude/admin set.
  startedAt       DateTime? // first time it moved to IN_PROGRESS
  estCompleteAt   DateTime?
  estTokens       Int?
  actualTokens    Int?
  // Post-ship lifecycle: SHIPPED ≠ done. An admin reviews and signs off to CLOSE.
  signoffRequired Boolean           @default(true)
  shippedAt       DateTime?
  closedAt        DateTime?
  closedBy        String? // admin email who signed off
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  // A Project groups an epic + its sub-tasks (e.g. the QR kiosk), formed from an idea.
  project         BuildProject?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId       String?
  events          BuildEvent[]
  subtasks        BuildSubtask[]
  dependencies    BuildDependency[] @relation("dependent") // edges: this item depends on others
  dependents      BuildDependency[] @relation("dependency") // edges: others depend on this item

  @@index([status])
  @@index([assignee, status])
  @@index([urgency])
  @@index([createdAt])
  @@index([projectId])
}

// A Project groups related board items (an epic + its sub-tasks) under one
// initiative — typically formed from an idea. Progress, errors and the count of
// user-gated (owner-input) items are derived from its items (see listProjects).
model BuildProject {
  id              String      @id @default(cuid())
  // Root of the reference tree for everything grouped under this project:
  // PRJ-<seq> → items PRJ-<seq>.<n> → subtasks PRJ-<seq>.<n>.<m>.
  // No @unique (deploy gate); unique by derivation from the sequence.
  seq             Int         @default(autoincrement())
  ref             String?
  slug            String      @unique
  name            String
  summary         String?     @db.Text
  status          String      @default("ACTIVE") // ACTIVE | PAUSED | DONE
  originIdeaTitle String? // the idea this project was formed from
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  items           BuildItem[]
}

// A directed dependency edge: `item` is blocked until `dependsOn` ships/closes.
// When the prerequisite completes, dependents auto-advance (see unblockDependents).
model BuildDependency {
  id          String    @id @default(cuid())
  item        BuildItem @relation("dependent", fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  dependsOn   BuildItem @relation("dependency", fields: [dependsOnId], references: [id], onDelete: Cascade)
  dependsOnId String
  createdAt   DateTime  @default(now())

  @@unique([itemId, dependsOnId])
  @@index([dependsOnId])
}

// A checklist item under a BuildItem, with its own status + assignee. When an
// owner-input subtask is completed by a person, it auto-triggers Claude to follow
// up on the parent (see lib/build-board.ts completeSubtask).
model BuildSubtask {
  id          String    @id @default(cuid())
  // Branches from the parent item's ref (BLD-7 → BLD-7.1; PRJ-3.1 → PRJ-3.1.2).
  // No @unique (deploy gate); allocation is lock-serialised per parent item.
  ref         String?
  item        BuildItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId      String
  title       String
  status      String    @default("TODO") // TODO | DOING | DONE
  assignee    String    @default("claude")
  ownerInput  Boolean   @default(false) // true → completing it pings Claude to action the parent
  order       Int       @default(0)
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([itemId, order])
}

model BuildEvent {
  id        String    @id @default(cuid())
  item      BuildItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId    String
  kind      String // created | status | urgency | assign | comment | blocker | github | shipped
  body      String?   @db.Text
  actor     String // staff email or 'claude'
  createdAt DateTime  @default(now())

  @@index([itemId, createdAt])
}

// Net Promoter Score — one per send; score is null until the client responds via
// the one-click email link (/nps/<token>). See lib/nps.ts.
model NpsResponse {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId    String?
  bookingId   String?
  treatment   String?
  score       Int? // 0–10
  comment     String?   @db.Text
  sentAt      DateTime  @default(now())
  respondedAt DateTime?

  @@index([clientId])
  @@index([respondedAt])
  @@index([sentAt])
}

// Planned-maintenance window, scheduled by Claude or an admin and shown on the
// Owner/Admin status page (and surfaceable to staff/clients later). See
// lib/maintenance.ts.
model MaintenanceWindow {
  id        String   @id @default(cuid())
  title     String
  detail    String?  @db.Text
  startAt   DateTime
  endAt     DateTime
  services  String[] @default([]) // affected compartments/services (status-page ids)
  impact    String? // e.g. "No expected downtime", "Booking briefly read-only"
  status    String   @default("SCHEDULED") // SCHEDULED | ACTIVE | DONE | CANCELLED
  createdBy String? // staff email or 'claude'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startAt])
}

// In-app notifications for staff/admin users — work assigned, comments/feedback
// on items they reported or own, mentions, etc. Shown in the header bell. See
// lib/notifications.ts.
model StaffNotification {
  id        String    @id @default(cuid())
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  kind      String // assigned | comment | status | idea_feedback | mention | system
  title     String
  body      String?   @db.Text
  href      String? // where clicking takes you (e.g. /admin/build)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ── Storefront "Skin & Smile" QR kiosk campaign ──────────────────────────────
// A storefront screen shows a QR; a visitor scans it on their phone, takes a
// selfie, gets a fun (non-clinical) AI skin & smile rating, shares it, and is
// routed to claim a reward. Public + anonymous-until-signup; short-lived
// sessions; photos deleted after 30 days (see /api/cron/kiosk-cleanup).

enum KioskStatus {
  ACTIVE
  PHOTO_TAKEN
  ANALYSIS_FAILED
  ANALYZED
  SHARED
  EXPIRED
  AGE_DECLINED // AI challenge-21 backstop failed — photos purged, no result
}

model KioskSession {
  id        String       @id @default(cuid())
  token     String       @unique
  secret    String? // BLD-159: capability secret carried in the QR (?s=); required to read/write the live camera feed
  status    KioskStatus  @default(ACTIVE)
  ipHash    String?
  photoUrl  String? // kept for back-compat with the single-photo v1 flow
  consentAt DateTime?
  result    KioskResult?
  createdAt DateTime     @default(now())
  expiresAt DateTime

  // ── Kiosk v2 live session (phone ↔ storefront display) ──
  stage         String    @default("idle") // live stage machine (lib/kiosk-live.ts)
  poseIdx       Int       @default(0) // current pose in the capture sequence
  photoUrls     String[]  @default([]) // multi-capture (max 4)
  liveFrame     String?   @db.Text // latest mirror frame as data-URL jpeg ≤120KB
  liveFrameAt   DateTime?
  ageDeclaredAt DateTime? // when the explicit 18+ tap happened
  updatedAt     DateTime  @default(now()) @updatedAt

  @@index([token])
  @@index([status, createdAt])
}

model KioskResult {
  id           String       @id @default(cuid())
  session      KioskSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId    String       @unique
  headline     String
  skinScore    Int
  smileScore   Int
  insights     String[]
  treatments   String[]
  photoUrl     String?
  shareSlug    String       @unique
  shareCount   Int          @default(0)
  // ── Kiosk v2 ──
  annotations  Json? // AI observations (KioskObservation[] — lib/kiosk-ai.ts)
  shareCaption String? // first-person caption for the share sheet
  bestPhotoUrl String? // chosen photo (session-scoped use only; NEVER on the public share page)
  // Share-to-claim reward: the single-use discount code issued to the visitor.
  claimCode    String?
  claimEmail   String?
  claimedAt    DateTime?
  createdAt    DateTime     @default(now())

  @@index([shareSlug])
}

model KioskEvent {
  id        String   @id @default(cuid())
  event     String // scan | consent | photo | analyzed | shared | claimed
  sessionId String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([sessionId])
}

// ── Device registry + hardware integrations (BLD-195) ───────────────────────
// A registry of the physical devices in a clinic — card terminals, storefront
// displays, sign-in kiosks, receipt printers. Terminals carry the provider +
// the provider's device id so the payment layer (lib/terminal.ts) can route an
// in-person capture to the right reader. New table only — additive, no @unique.
enum DeviceKind {
  TERMINAL // card payment terminal (e.g. Tyl by NatWest)
  DISPLAY // storefront / waiting-room / treatment-room screen (e.g. iiyama TW1023ASC)
  KIOSK // self-service sign-in kiosk
  SCANNER // barcode scanner (e.g. Zebra DS2278 keyboard-wedge)
  PRINTER // receipt / label printer
  OTHER
}

model Device {
  id         String     @id @default(cuid())
  name       String // friendly label ("Reception terminal")
  kind       DeviceKind @default(TERMINAL)
  provider   String? // e.g. "tyl" for card terminals
  externalId String? // the provider's device / POI id
  location   String? // "Reception", "Room 1"
  station    String? // reception | room (mirrors BLD-202)
  // BLD-225 — a DISPLAY mounted outside a treatment room shows that room's live
  // status. roomId references a Resource (ROOM) by id; token secures the public
  // /room-display/[token] URL the panel loads. No @unique (deploy-gate safe) —
  // token is a cuid, collision-proof by construction.
  roomId     String?
  token      String?
  active     Boolean    @default(true)
  lastSeenAt DateTime?
  notes      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([kind, active])
}

// ── Editable, versioned health questionnaires (BLD-209) ─────────────────────
// Admins can edit the core Medical History questions. Each publish writes a new
// immutable snapshot here (version = max existing + 1). The live portal form uses
// the latest version; a saved HealthAssessment records key@version, and the
// clinician view resolves the snapshot for THAT version so every past form always
// renders with the exact wording the client was shown (audit / insurer requests).
// New table — additive; uniqueness of (key,version) is enforced structurally
// (publish allocates max+1), not via a @unique constraint (deploy-gate safe).
model QuestionnaireVersion {
  id        String   @id @default(cuid())
  key       String // questionnaire key, e.g. "medical-history"
  version   Int // monotonically increasing per key
  type      String
  title     String
  intro     String?
  questions Json // full Question[] snapshot
  createdAt DateTime @default(now())
  createdBy String?

  @@index([key, version])
}

// ── Scheduled per-room block-outs (BLD-198) ─────────────────────────────────
// A room can be blocked from availability in advance (e.g. a contractor on
// site) and reactivated afterwards. Availability treats an active closure like a
// booking occupying the room for [startAt, effectiveEnd]; ending it (early or at
// endAt) marks the room's RoomPrep DIRTY so a cleaning is required before the
// next client session. New table — additive.
model RoomClosure {
  id           String    @id @default(cuid())
  room         Resource  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId       String
  startAt      DateTime
  endAt        DateTime
  reason       String?
  createdBy    String?
  endedEarlyAt DateTime?
  endedEarlyBy String?
  createdAt    DateTime  @default(now())

  @@index([roomId, startAt, endAt])
}

// ── Cancellation waitlist (BLD-133) ─────────────────────────────────────────
// A client asks to be told if a slot for a treatment frees up within a date
// window. On cancellation we notify the first matching ACTIVE entry with a
// time-boxed one-click claim link (phase 2); it then rolls to the next.
enum WaitlistStatus {
  ACTIVE // waiting
  NOTIFIED // emailed a freed slot; claim link live until expiresAt
  CLAIMED // booked the freed slot
  EXPIRED // claim window passed
  CANCELLED // withdrawn
}

model WaitlistEntry {
  id             String         @id @default(cuid())
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId       String
  treatmentSlug  String
  treatmentTitle String
  fromDate       DateTime // window start (inclusive, date)
  toDate         DateTime // window end (inclusive, date)
  status         WaitlistStatus @default(ACTIVE)
  claimToken     String? // secures the one-click claim link (phase 2)
  offeredStart   DateTime? // the freed slot offered on notify
  notifiedAt     DateTime?
  expiresAt      DateTime?
  claimedAt      DateTime? // when the offered slot was booked (phase 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([treatmentSlug, status])
  @@index([clientId])
}
