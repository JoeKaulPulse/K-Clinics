// K Clinics CRM — data model
// Postgres in production (Neon/Supabase). `prisma db push` to sync.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConsultStatus {
  NEW
  CONTACTED
  BOOKED
  COMPLETED
  CLOSED
}

enum InteractionType {
  NOTE
  CALL
  EMAIL
  SMS
  APPOINTMENT
  SYSTEM
}

enum EmailKind {
  CONSULT_REPLY
  CONSULT_NOTIFY
  BIRTHDAY
  FOLLOW_UP
  WIN_BACK
  REVIEW_REQUEST
  CAMPAIGN
  MANUAL
}

enum EmailStatus {
  QUEUED
  SENT
  FAILED
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Role {
  OWNER
  STAFF
}

model Client {
  id              String         @id @default(cuid())
  firstName       String
  lastName        String?
  email           String         @unique
  phone           String?
  dob             DateTime?      // drives birthday automation
  source          String?        // website, treatwell, fresha, referral…
  tags            String[]       @default([])
  notes           String?
  marketingOptIn  Boolean        @default(false)
  unsubscribed    Boolean        @default(false)
  unsubToken      String         @unique @default(cuid())
  lastVisitAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  consultations   Consultation[]
  interactions    Interaction[]
  appointments    Appointment[]
  emails          EmailEvent[]

  @@index([createdAt])
  @@index([dob])
}

model Consultation {
  id              String        @id @default(cuid())
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String
  category        String        // aesthetics | dentistry | both
  treatments      String[]      @default([])
  concerns        String?
  message         String?
  preferredTime   String?
  preferredContact String?      // email | phone | whatsapp
  medicalNotes    String?
  status          ConsultStatus @default(NEW)
  assignedTo      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Interaction {
  id        String          @id @default(cuid())
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId  String
  type      InteractionType @default(NOTE)
  summary   String
  detail    String?
  author    String?
  createdAt DateTime        @default(now())

  @@index([clientId, createdAt])
}

model Appointment {
  id         String            @id @default(cuid())
  client     Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  treatment  String
  scheduledAt DateTime
  status     AppointmentStatus @default(SCHEDULED)
  followUpSent Boolean         @default(false)
  reviewSent Boolean           @default(false)
  createdAt  DateTime          @default(now())

  @@index([scheduledAt])
}

model EmailEvent {
  id         String      @id @default(cuid())
  client     Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  clientId   String?
  kind       EmailKind
  to         String
  subject    String
  status     EmailStatus @default(QUEUED)
  providerId String?
  error      String?
  meta       Json?
  createdAt  DateTime    @default(now())

  @@index([clientId])
  @@index([kind, createdAt])
}

model Campaign {
  id          String   @id @default(cuid())
  name        String
  subject     String
  body        String
  segment     String?  // tag or rule used to select recipients
  sentAt      DateTime?
  recipients  Int      @default(0)
  createdAt   DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())
}
